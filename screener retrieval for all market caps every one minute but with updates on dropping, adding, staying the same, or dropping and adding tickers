input("Log in to Finviz Elite, then come back to PyCharm and press ENTER: ")


def wait_for_download(before_files):
    start_time = time.time()

    while time.time() - start_time < 30:
        after_files = set(os.listdir(DOWNLOAD_DIR))
        new_files = after_files - before_files

        csv_files = [f for f in new_files if f.endswith(".csv")]

        if csv_files:
            return os.path.join(DOWNLOAD_DIR, csv_files[0])

        time.sleep(1)

    return None


def get_status(market_cap_name, csv_path):
    df = pd.read_csv(csv_path)

    if "Ticker" not in df.columns:
        return "unknown"

    current_tickers = set(df["Ticker"].dropna().astype(str))

    if market_cap_name not in previous_tickers:
        previous_tickers[market_cap_name] = current_tickers
        return "first"

    old_tickers = previous_tickers[market_cap_name]

    added = current_tickers - old_tickers
    dropped = old_tickers - current_tickers

    previous_tickers[market_cap_name] = current_tickers

    if added and dropped:
        return "added_dropped"
    elif added:
        return "added"
    elif dropped:
        return "dropped"
    else:
        return "same"


while True:
    timestamp = datetime.now().strftime("%Y-%m-%d_%H-%M-%S")
    loop_start_time = time.time()

    for market_cap_name, url in URLS.items():
        before_files = set(os.listdir(DOWNLOAD_DIR))

        driver.get(url)

        downloaded_path = wait_for_download(before_files)

        if downloaded_path:
            status = get_status(market_cap_name, downloaded_path)

            new_filename = f"{market_cap_name}_{status}_{timestamp}.csv"
            new_path = os.path.join(DOWNLOAD_DIR, new_filename)

            os.rename(downloaded_path, new_path)

            print(f"Saved: {new_filename}")
        else:
            print(f"No CSV downloaded for {market_cap_name}")

        time.sleep(2)

    elapsed_time = time.time() - loop_start_time
    wait_time = max(0, 60 - elapsed_time)

    print(f"Finished scan for {timestamp}. Waiting {round(wait_time)} seconds...")
    time.sleep(wait_time)
