# ---------------------------------------------------------------------------
# 7. PER-WINDOW ANALYSIS
# ---------------------------------------------------------------------------

def analyze_window(window_minutes, tickers, ticker_data_cache, cfg):
    """
    Run the full analysis for one rolling-window size.
    Returns (avg_pct_gain, unique_ticker_count).
    ticker_data_cache: dict of {ticker: {"price": df, "msg": df}} to avoid re-fetching.
    """
    windows_meta = build_rolling_windows(
        cfg["entry_time"], cfg["exit_time"],
        window_minutes, cfg["date"],
    )

    all_trades = []

    for ticker in tickers:
        cached = ticker_data_cache.get(ticker)
        if cached is None:
            continue

        price_df = cached["price"]
        msg_df   = cached["msg"]

        if price_df.empty:
            continue

        # Compute max_weight across all windows
        all_msg_windows = []
        for ws, we in windows_meta:
            m = msg_df[(msg_df["datetime"] >= ws) & (msg_df["datetime"] < we)] if not msg_df.empty else pd.DataFrame()
            b   = int(m["bull"].sum())   if not m.empty else 0
            br  = int(m["bear"].sum())   if not m.empty else 0
            t   = int(m["tagged"].sum()) if not m.empty else 0
            tot = int(m["total"].sum())  if not m.empty else 0
            all_msg_windows.append((b, br, t, tot))

        max_weight = max(
            (abs((b - br) / t * math.log(1 + tot))
             for b, br, t, tot in all_msg_windows if t > 0),
            default=1.0,
        )

        window_data = []
        for (ws, we), (b, br, t, tot) in zip(windows_meta, all_msg_windows):
            p  = price_df[(price_df["datetime"] >= ws) & (price_df["datetime"] < we)]
            po = p["close"].iloc[0]  if len(p) >= 1 else float("nan")
            pc = p["close"].iloc[-1] if len(p) >= 1 else float("nan")
            mpm   = tot / window_minutes
            score = calc_sentiment_score(b, br, t, tot, max_weight)
            window_data.append({
                "w_start":     ws,
                "w_end":       we,
                "price_open":  po,
                "price_close": pc,
                "total_msgs":  tot,
                "bull":        b,
                "bear":        br,
                "tagged":      t,
                "msg_per_min": mpm,
                "sentiment":   score,
            })

        trades = find_trade_signals(
            ticker, window_data,
            CORR_THRESHOLD, MSG_THRESHOLD,
            USE_CORR, USE_MSG,
        )
        all_trades.extend(trades)

    if not all_trades:
        return float("nan"), 0

    df = pd.DataFrame(all_trades)
    avg_gain      = df["pct_change"].mean()
    unique_tickers = df["ticker"].nunique()
    return avg_gain, unique_tickers


