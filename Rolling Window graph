# ---------------------------------------------------------------------------
# HELPERS
# ---------------------------------------------------------------------------

def curl_get(url, params=None, timeout=30):
    return curl_requests.get(
        url,
        params=params,
        timeout=timeout,
        impersonate="chrome110",
        headers={"User-Agent": "Mozilla/5.0"},
        allow_redirects=True,
    )


def hhmm_to_minutes(hhmm):
    h, m = map(int, hhmm.split(":"))
    return h * 60 + m


# ---------------------------------------------------------------------------
# 1. SCREENER
# ---------------------------------------------------------------------------

def build_screener_url(market_cap, relvol_filter):
    filters = ",".join([
        RAW_CAP_FILTERS[market_cap],
        CURRENT_VOLUME,
        relvol_filter,
        CHANGE_FILTERS[market_cap],
    ])
    encoded = quote(filters, safe="")
    return "https://elite.finviz.com/export?v=111&f=" + encoded + "&ft=3&auth=" + AUTH_TOKEN


def get_top_tickers(market_cap):
    print("\n[Screener] Fetching tickers for market cap: " + market_cap)
    best_tickers = []
    best_diff = float("inf")

    for relvol in RELATIVE_VOLUME_OPTIONS:
        url = build_screener_url(market_cap, relvol)
        try:
            resp = curl_get(url, timeout=30)
            if resp.status_code != 200:
                continue
            preview = resp.text[:300]
            if preview.strip().startswith("<!") or preview.strip().lower().startswith("<html"):
                print("  [DEBUG] Got HTML — likely auth/login redirect. Check your token.")
                break
            df = pd.read_csv(StringIO(resp.text))
            col_map = {c.strip().lower(): c for c in df.columns}
            if "ticker" not in col_map:
                continue
            df = df.rename(columns={col_map["ticker"]: "Ticker"})
            tickers = df["Ticker"].dropna().astype(str).tolist()
            diff = abs(len(tickers) - TARGET_TICKERS)
            print("  " + relvol + ": " + str(len(tickers)) + " tickers")
            if diff < best_diff:
                best_diff = diff
                best_tickers = tickers
            if len(tickers) >= TARGET_TICKERS - 5:
                break
        except Exception as e:
            print("  Warning [" + relvol + "]: " + str(e))
        time.sleep(0.5)

    print("  -> Selected " + str(len(best_tickers)) + " tickers")
    return best_tickers[:50]


