# 8. MAIN
# ---------------------------------------------------------------------------

def main():
    cfg = get_user_inputs()

    # --- Ticker source: Colab upload widget ---
    try:
        from google.colab import files as colab_files
        use_colab = True
    except ImportError:
        use_colab = False

    tickers = []
    if use_colab:
        print("Opening file picker — select your tickers CSV (or close/cancel to use live screener).")
        uploaded = colab_files.upload()
        if not uploaded:
            print("No file uploaded. Falling back to live screener.")
        else:
            filename = list(uploaded.keys())[0]
            ticker_path = "/content/" + filename
            df_src = pd.read_csv(ticker_path)
            col_map = {c.strip().lower(): c for c in df_src.columns}
            if "ticker" not in col_map:
                print("No Ticker column found in file. Columns: " + str(df_src.columns.tolist()))
                sys.exit(1)
            tickers = df_src[col_map["ticker"]].dropna().astype(str).str.strip().tolist()
            print("Loaded " + str(len(tickers)) + " tickers from: " + filename)
    else:
        ticker_source = input(
            "Ticker source — enter path to CSV file, or press Enter to use live screener: "
        ).strip()
        if ticker_source:
            if not os.path.exists(ticker_source):
                print("File not found: " + ticker_source)
                sys.exit(1)
            df_src = pd.read_csv(ticker_source)
            col_map = {c.strip().lower(): c for c in df_src.columns}
            if "ticker" not in col_map:
                print("No Ticker column found in file.")
                sys.exit(1)
            tickers = df_src[col_map["ticker"]].dropna().astype(str).str.strip().tolist()
            print("Loaded " + str(len(tickers)) + " tickers from file.")

    if not tickers:
        tickers = get_top_tickers(cfg["market_cap"])
        if not tickers:
            print("\n[!] Screener returned 0 tickers.")
            manual = input("Enter tickers comma-separated or press Enter to exit: ").strip()
            if not manual:
                sys.exit(1)
            tickers = [t.strip().upper() for t in manual.split(",") if t.strip()]

    # --- Pre-fetch all price & sentiment data once ---
    print("\n[Data Fetch] Downloading price and sentiment data for all tickers...")
    ticker_data_cache = {}
    for ticker in tickers:
        print("  Fetching: " + ticker)
        price_df = get_price_data(ticker, cfg["date"])
        msg_df   = fetch_stocktwits_messages(ticker, cfg["date"])
        if not price_df.empty:
            ticker_data_cache[ticker] = {"price": price_df, "msg": msg_df}
        else:
            print("    -> No price data, skipping.")
        time.sleep(0.4)

    print("\n[Cache] " + str(len(ticker_data_cache)) + " tickers with price data.")

    # --- Sweep windows 5 to 120 in steps of 5 ---
    window_sizes  = list(range(WINDOW_START, WINDOW_END + 1, WINDOW_STEP))
    avg_gains     = []
    ticker_counts = []

    print("\n[Sweep] Analyzing " + str(len(window_sizes)) + " window sizes...\n")
    for wm in window_sizes:
        print("  Window: " + str(wm) + " min", end="  ")
        avg_gain, n_tickers = analyze_window(wm, tickers, ticker_data_cache, cfg)
        avg_gains.append(avg_gain)
        ticker_counts.append(n_tickers)
        gain_str   = ("%.2f%%" % avg_gain)   if not math.isnan(avg_gain) else "n/a"
        print("avg gain: " + gain_str + "  tickers: " + str(n_tickers))

    # --- Build summary table internally (not printed) ---
    summary_df = pd.DataFrame({
        "window_minutes": window_sizes,
        "avg_pct_gain":   avg_gains,
        "unique_tickers": ticker_counts,
    })

    # --- Plot ---
    fig, ax1 = plt.subplots(figsize=(13, 6))

    color_gain    = "#2196F3"   # blue
    color_tickers = "#FF6B35"   # orange

    ax1.set_xlabel("Rolling Window (minutes)", fontsize=12)
    ax1.set_ylabel("Avg % Gain per Trade", color=color_gain, fontsize=12)
    line1, = ax1.plot(
        summary_df["window_minutes"],
        summary_df["avg_pct_gain"],
        color=color_gain, linewidth=2.2, marker="o", markersize=5, label="Avg % Gain",
    )
    ax1.tick_params(axis="y", labelcolor=color_gain)
    ax1.yaxis.set_major_formatter(mticker.FormatStrFormatter("%.1f%%"))
    ax1.set_xticks(window_sizes)
    ax1.tick_params(axis="x", rotation=45)
    ax1.grid(axis="y", linestyle="--", alpha=0.4)

    ax2 = ax1.twinx()
    ax2.set_ylabel("Unique Tickers with Signals", color=color_tickers, fontsize=12)
    line2, = ax2.plot(
        summary_df["window_minutes"],
        summary_df["unique_tickers"],
        color=color_tickers, linewidth=2.2, marker="s", markersize=5,
        linestyle="--", label="Unique Tickers",
    )
    ax2.tick_params(axis="y", labelcolor=color_tickers)
    ax2.yaxis.set_major_locator(mticker.MaxNLocator(integer=True))

    lines = [line1, line2]
    labels = [l.get_label() for l in lines]
    ax1.legend(lines, labels, loc="upper left", fontsize=10)

    plt.title(
        "Rolling Window Sweep — Avg % Gain & Unique Tickers\n"
        + cfg["market_cap"].capitalize() + " Cap  |  " + cfg["date"],
        fontsize=13, pad=14,
    )
    plt.tight_layout()

    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    plot_path = os.path.join(
        DOWNLOADS_DIR,
        "window_sweep_" + cfg["market_cap"] + "_" + cfg["date"] + "_" + timestamp + ".png",
    )
    plt.savefig(plot_path, dpi=150)
    plt.show()
    print("\nGraph saved to: " + plot_path)


if __name__ == "__main__":
    main()
