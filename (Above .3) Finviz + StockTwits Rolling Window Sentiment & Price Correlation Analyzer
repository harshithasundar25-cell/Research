def curl_get(url: str, params: dict = None, timeout: int = 30) -> curl_requests.Response:
    """GET with curl-impersonate (Chrome 110) to bypass bot detection."""
    return curl_requests.get(
        url,
        params=params,
        timeout=timeout,
        impersonate="chrome110",
        headers={"User-Agent": "Mozilla/5.0"},
        allow_redirects=True,
    )


def hhmm_to_minutes(hhmm: str) -> int:
    h, m = map(int, hhmm.split(":"))
    return h * 60 + m


def minutes_to_hhmm(minutes: int) -> str:
    return f"{minutes // 60:02d}:{minutes % 60:02d}"


# ─────────────────────────────────────────────────────────────────────────────
# 1. SCREENER  —  top ~30 tickers for a given market cap
# ─────────────────────────────────────────────────────────────────────────────

def build_screener_url(market_cap: str, relvol_filter: str) -> str:
    filters = ",".join([
        RAW_CAP_FILTERS[market_cap],
        CURRENT_VOLUME,
        relvol_filter,
        CHANGE_FILTERS[market_cap],
    ])
    encoded = quote(filters, safe="")
    return (
        f"https://elite.finviz.com/export?v=111"
        f"&f={encoded}&ft=3&auth={AUTH_TOKEN}"
    )


def get_top_tickers(market_cap: str) -> list[str]:
    """
    Iterate relative-volume filters and pick the one whose ticker count is
    closest to TARGET_TICKERS (≈30).
    """
    print(f"\n[Screener] Fetching tickers for market cap: {market_cap}")
    best_tickers: list[str] = []
    best_diff = float("inf")

    for relvol in RELATIVE_VOLUME_OPTIONS:
        url = build_screener_url(market_cap, relvol)
        try:
            resp = curl_get(url, timeout=30)
            if resp.status_code != 200:
                continue
            df = pd.read_csv(StringIO(resp.text))
            if "Ticker" not in df.columns:
                continue
            tickers = df["Ticker"].dropna().astype(str).tolist()
            diff = abs(len(tickers) - TARGET_TICKERS)
            print(f"  {relvol}: {len(tickers)} tickers")
            if diff < best_diff:
                best_diff = diff
                best_tickers = tickers
        except Exception as e:
            print(f"  Warning [{relvol}]: {e}")
        time.sleep(0.5)

    print(f"  → Selected {len(best_tickers)} tickers")
    return best_tickers[:50]  # cap at 50 for safety


