# 2. PRICE DATA  —  1-min OHLCV from Finviz quote_export
# ─────────────────────────────────────────────────────────────────────────────

def get_price_data(ticker: str, date: str) -> pd.DataFrame:
    """
    Returns a DataFrame with columns [datetime, close] indexed by minute.
    date: 'YYYY-MM-DD'
    """
    url = (
        f"https://elite.finviz.com/quote_export?"
        f"t={ticker}&p=i1&s={date}&e={date}&auth={AUTH_TOKEN}"
    )
    try:
        resp = curl_get(url, timeout=30)
        if resp.status_code != 200:
            return pd.DataFrame()
        df = pd.read_csv(StringIO(resp.text))
        df.columns = [c.strip().lower() for c in df.columns]

        dt_col = next(
            (c for c in df.columns if "date" in c or "time" in c), None
        )
        if dt_col is None:
            return pd.DataFrame()

        # Strip AM/PM suffix Finviz sometimes adds
        df[dt_col] = (
            df[dt_col].astype(str).str.replace(r"\s+(AM|PM)$", "", regex=True)
        )
        df[dt_col] = pd.to_datetime(
            df[dt_col], format="%m/%d/%Y %H:%M", errors="coerce"
        )
        df = df.dropna(subset=[dt_col])
        df = df.rename(columns={dt_col: "datetime"})

        # Localize to EST
        if df["datetime"].dt.tz is None:
            df["datetime"] = df["datetime"].dt.tz_localize(EST)

        return df[["datetime", "close"]].sort_values("datetime").reset_index(drop=True)

    except Exception as e:
        print(f"    Price fetch error for {ticker}: {e}")
        return pd.DataFrame()


# ─────────────────────────────────────────────────────────────────────────────
# 3. STOCKTWITS SENTIMENT  —  messages within a date range
# ─────────────────────────────────────────────────────────────────────────────

def fetch_stocktwits_messages(ticker: str, date: str) -> pd.DataFrame:
    """
    Pull StockTwits messages for a ticker on a given date.
    Returns DataFrame with [datetime, bull, bear, tagged, total].
    The public API returns at most ~30 messages per call; we page back.
    """
    base = f"https://api.stocktwits.com/api/2/streams/symbol/{ticker}.json"
    date_dt = datetime.strptime(date, "%Y-%m-%d")
    day_start = EST.localize(date_dt.replace(hour=0, minute=0, second=0))
    day_end   = EST.localize(date_dt.replace(hour=23, minute=59, second=59))

    rows = []
    max_id = None
    stop = False
    page = 0

    while not stop and page < 40:  # safety cap
        params = {"limit": 30}
        if max_id:
            params["max"] = max_id

        try:
            resp = curl_get(base, params=params, timeout=20)
            if resp.status_code != 200:
                break
            data = resp.json()
        except Exception:
            break

        messages = data.get("messages", [])
        if not messages:
            break

        for msg in messages:
            raw_ts = msg.get("created_at", "")
            try:
                # StockTwits returns UTC ISO-8601
                ts_utc = datetime.strptime(raw_ts, "%Y-%m-%dT%H:%M:%SZ")
                ts_utc = pytz.utc.localize(ts_utc)
                ts_est = ts_utc.astimezone(EST)
            except Exception:
                continue

            if ts_est < day_start:
                stop = True
                break
            if ts_est > day_end:
                continue

            sentiment = (msg.get("entities") or {}).get("sentiment") or {}
            label = (sentiment.get("basic") or "").lower()
            bull = 1 if label == "bullish" else 0
            bear = 1 if label == "bearish" else 0
            tagged = 1 if label in ("bullish", "bearish") else 0

            rows.append({
                "datetime": ts_est,
                "bull":    bull,
                "bear":    bear,
                "tagged":  tagged,
                "total":   1,
            })

        max_id = messages[-1].get("id")
        page += 1
        time.sleep(0.3)

    if not rows:
        return pd.DataFrame(columns=["datetime", "bull", "bear", "tagged", "total"])

    df = pd.DataFrame(rows).sort_values("datetime").reset_index(drop=True)
    return df


# ─────────────────────────────────────────────────────────────────────────────
# 4. ROLLING WINDOW CALCULATIONS
# ─────────────────────────────────────────────────────────────────────────────

def calc_sentiment_score(bull, bear, tagged, total, max_weight=1.0):
    """
    score = [(Bull - Bear) / Tagged × log(1 + Total)] / max_weight
    Returns NaN if tagged == 0.
    """
    if tagged == 0 or max_weight == 0:
        return float("nan")
    return ((bull - bear) / tagged * math.log(1 + total)) / max_weight


def build_rolling_windows(
    start_hhmm: str,
    end_hhmm: str,
    window_minutes: int,
    date: str,
) -> list[tuple[datetime, datetime]]:
    """Generate rolling 1-min step windows within [start, end]."""
    base = datetime.strptime(date, "%Y-%m-%d")
    start_min = hhmm_to_minutes(start_hhmm)
    end_min   = hhmm_to_minutes(end_hhmm)

    windows = []
    cur = start_min
    while cur + window_minutes <= end_min + 1:
        w_start = EST.localize(
            base.replace(hour=cur // 60, minute=cur % 60, second=0)
        )
        w_end = EST.localize(
            base.replace(
                hour=(cur + window_minutes) // 60,
                minute=(cur + window_minutes) % 60,
                second=0,
            )
        )
        windows.append((w_start, w_end))
        cur += 1
    return windows


def window_metrics(
    price_df: pd.DataFrame,
    msg_df: pd.DataFrame,
    w_start: datetime,
    w_end: datetime,
    window_minutes: int,
    max_weight: float,
) -> dict:
    """Compute metrics for a single rolling window."""
    # Price slice
    p = price_df[
        (price_df["datetime"] >= w_start) & (price_df["datetime"] < w_end)
    ]
    # Message slice
    m = msg_df[
        (msg_df["datetime"] >= w_start) & (msg_df["datetime"] < w_end)
    ]

    price_open  = p["close"].iloc[0]  if len(p) >= 1 else float("nan")
    price_close = p["close"].iloc[-1] if len(p) >= 1 else float("nan")

    total_msgs  = int(m["total"].sum())
    bull        = int(m["bull"].sum())
    bear        = int(m["bear"].sum())
    tagged      = int(m["tagged"].sum())
    msg_per_min = total_msgs / window_minutes if window_minutes > 0 else float("nan")

    score = calc_sentiment_score(bull, bear, tagged, total_msgs, max_weight)

    return {
        "w_start":      w_start,
        "w_end":        w_end,
        "price_open":   price_open,
        "price_close":  price_close,
        "total_msgs":   total_msgs,
        "bull":         bull,
        "bear":         bear,
        "tagged":       tagged,
        "msg_per_min":  msg_per_min,
        "sentiment":    score,
    }


def safe_corr(x, y) -> float:
    """Pearson r; returns NaN if insufficient data."""
    x = [v for v, w in zip(x, y) if not math.isnan(v) and not math.isnan(w)]
    y = [w for v, w in zip(x, y) if not math.isnan(v) and not math.isnan(w)]
    if len(x) < 3:
        return float("nan")
    try:
        r, _ = pearsonr(x, y)
        return r
    except Exception:
        return float("nan")


# ─────────────────────────────────────────────────────────────────────────────
# 5. TRADE SIGNAL LOGIC
# ─────────────────────────────────────────────────────────────────────────────

def find_trade_signals(
    ticker: str,
    all_windows: list[dict],
    corr_threshold: float | None,
    msg_threshold: float | None,
    use_corr: bool,
    use_msg: bool,
) -> list[dict]:
    """
    Scan rolling windows in order. Enter when conditions are met; exit when any
    condition fails. Returns a list of completed trades.
    """
    trades = []
    in_trade = False
    entry_idx = None

    # Pre-compute per-window rolling correlations (need ≥3 windows look-back)
    prices      = [w["price_close"] for w in all_windows]
    densities   = [w["msg_per_min"] for w in all_windows]
    sentiments  = [w["sentiment"]   for w in all_windows]

    corr_pd = []   # price vs density
    corr_ps = []   # price vs sentiment
    for i in range(len(all_windows)):
        lo = max(0, i - 9)  # 10-window look-back for correlation
        r_pd = safe_corr(prices[lo:i+1], densities[lo:i+1])
        r_ps = safe_corr(prices[lo:i+1], sentiments[lo:i+1])
        corr_pd.append(r_pd)
        corr_ps.append(r_ps)

    for i, w in enumerate(all_windows):
        price_rising = (
            not math.isnan(w["price_open"])
            and not math.isnan(w["price_close"])
            and w["price_close"] > w["price_open"]
        )
        corr_ok = True
        msg_ok  = True

        if use_corr and corr_threshold is not None:
            r_pd = corr_pd[i]
            r_ps = corr_ps[i]
            corr_ok = (
                not math.isnan(r_pd)
                and not math.isnan(r_ps)
                and r_pd >= corr_threshold
                and r_ps >= corr_threshold
            )

        if use_msg and msg_threshold is not None:
            msg_ok = (
                not math.isnan(w["msg_per_min"])
                and w["msg_per_min"] >= msg_threshold
            )

        # Entry condition
        if not in_trade:
            entry_signal = price_rising and (corr_ok or msg_ok)
            if entry_signal:
                in_trade  = True
                entry_idx = i

        # Exit condition (evaluate even on entry bar)
        else:
            exit_reason = None
            if not price_rising:
                exit_reason = "price_decreasing"
            elif use_corr and not corr_ok:
                exit_reason = f"corr_below_{corr_threshold}"
            elif use_msg and not msg_ok:
                exit_reason = f"msg_below_{msg_threshold}"

            if exit_reason or i == len(all_windows) - 1:
                if exit_reason is None:
                    exit_reason = "end_of_window"

                entry_w = all_windows[entry_idx]
                exit_w  = all_windows[i]

                entry_price = entry_w["price_open"]
                exit_price  = exit_w["price_close"]
                pct_change  = (
                    (exit_price - entry_price) / entry_price * 100
                    if entry_price and entry_price != 0 else float("nan")
                )

                # Aggregate sentiment between entry and exit
                trade_windows = all_windows[entry_idx:i+1]
                total_m   = sum(tw["total_msgs"]  for tw in trade_windows)
                total_b   = sum(tw["bull"]        for tw in trade_windows)
                total_br  = sum(tw["bear"]        for tw in trade_windows)
                total_t   = sum(tw["tagged"]      for tw in trade_windows)
                avg_mpm   = sum(tw["msg_per_min"] for tw in trade_windows) / len(trade_windows)

                # Recompute max_weight across all windows for normalisation
                max_weight = max(
                    (abs((tw["bull"] - tw["bear"]) / tw["tagged"] * math.log(1 + tw["total_msgs"]))
                     for tw in trade_windows if tw["tagged"] > 0),
                    default=1.0,
                )
                trade_sentiment = calc_sentiment_score(
                    total_b, total_br, total_t, total_m, max_weight
                )

                trades.append({
                    "ticker":             ticker,
                    "entry_window":       entry_w["w_start"].strftime("%H:%M"),
                    "exit_window":        exit_w["w_end"].strftime("%H:%M"),
                    "entry_price":        round(entry_price, 4) if not math.isnan(entry_price) else None,
                    "exit_price":         round(exit_price,  4) if not math.isnan(exit_price)  else None,
                    "pct_change":         round(pct_change,  4) if not math.isnan(pct_change)  else None,
                    "entry_corr_price_density":    round(corr_pd[entry_idx], 4) if not math.isnan(corr_pd[entry_idx]) else None,
                    "entry_corr_price_sentiment":  round(corr_ps[entry_idx], 4) if not math.isnan(corr_ps[entry_idx]) else None,
                    "exit_corr_price_density":     round(corr_pd[i], 4)         if not math.isnan(corr_pd[i])         else None,
                    "exit_corr_price_sentiment":   round(corr_ps[i], 4)         if not math.isnan(corr_ps[i])         else None,
                    "avg_msg_per_min":    round(avg_mpm,        4) if not math.isnan(avg_mpm)  else None,
                    "trade_sentiment":    round(trade_sentiment, 4) if not math.isnan(trade_sentiment) else None,
                    "exit_reason":        exit_reason,
                })
                in_trade  = False
                entry_idx = None

    return trades


