def prompt(label: str, default: str = "") -> str:
    val = input(f"{label}: ").strip()
    return val if val else default


def get_user_inputs() -> dict:
    print("\n" + "=" * 60)
    print("  Finviz + StockTwits Sentiment / Price Correlation Tool")
    print("=" * 60)

    market_cap = ""
    while market_cap not in RAW_CAP_FILTERS:
        market_cap = prompt(
            f"Market cap ({'/'.join(RAW_CAP_FILTERS.keys())})"
        ).lower()

    date = prompt("Date (YYYY-MM-DD)")

    entry_time = prompt("Entry time (HH:MM, 24-hr EST, e.g. 09:30)")
    exit_time  = prompt("Exit time  (HH:MM, 24-hr EST, e.g. 16:00)")

    window_minutes = int(prompt("Rolling window size in minutes (e.g. 5)"))

    # Correlation threshold
    corr_raw = prompt(
        "Correlation threshold (0-1, or 'no' to skip correlation as signal)"
    ).lower()
    use_corr       = corr_raw != "no"
    corr_threshold = float(corr_raw) if use_corr else None

    # Messages-per-minute threshold
    msg_raw = prompt(
        "Messages-per-minute threshold (e.g. 2.0, or 'no' to skip)"
    ).lower()
    use_msg       = msg_raw != "no"
    msg_threshold = float(msg_raw) if use_msg else None

    return {
        "market_cap":      market_cap,
        "date":            date,
        "entry_time":      entry_time,
        "exit_time":       exit_time,
        "window_minutes":  window_minutes,
        "use_corr":        use_corr,
        "corr_threshold":  corr_threshold,
        "use_msg":         use_msg,
        "msg_threshold":   msg_threshold,
    }


# ─────────────────────────────────────────────────────────────────────────────
# 7. MAIN
# ─────────────────────────────────────────────────────────────────────────────

def main():
    cfg = get_user_inputs()

    # ── Step 1: get tickers ──────────────────────────────────────────────────
    tickers = get_top_tickers(cfg["market_cap"])
    if not tickers:
        print("No tickers found. Exiting.")
        sys.exit(1)

    windows_meta = build_rolling_windows(
        cfg["entry_time"],
        cfg["exit_time"],
        cfg["window_minutes"],
        cfg["date"],
    )
    print(f"\n[Windows] {len(windows_meta)} rolling windows "
          f"({cfg['entry_time']} → {cfg['exit_time']}, {cfg['window_minutes']}min each)")

    all_trades: list[dict] = []

    for ticker in tickers:
        print(f"\n[{ticker}] Fetching price & sentiment data…")

        price_df = get_price_data(ticker, cfg["date"])
        msg_df   = fetch_stocktwits_messages(ticker, cfg["date"])

        if price_df.empty:
            print(f"  No price data — skipping.")
            continue

        # Compute max_weight across all windows for normalisation
        all_msg_windows = []
        for ws, we in windows_meta:
            m = msg_df[(msg_df["datetime"] >= ws) & (msg_df["datetime"] < we)]
            b  = int(m["bull"].sum())   if not msg_df.empty else 0
            br = int(m["bear"].sum())   if not msg_df.empty else 0
            t  = int(m["tagged"].sum()) if not msg_df.empty else 0
            tot = int(m["total"].sum()) if not msg_df.empty else 0
            all_msg_windows.append((b, br, t, tot))

        max_weight = max(
            (abs((b - br) / t * math.log(1 + tot))
             for b, br, t, tot in all_msg_windows if t > 0),
            default=1.0,
        )

        # Build per-window metrics
        window_data = []
        for (ws, we), (b, br, t, tot) in zip(windows_meta, all_msg_windows):
            p = price_df[
                (price_df["datetime"] >= ws) & (price_df["datetime"] < we)
            ]
            po = p["close"].iloc[0]  if len(p) >= 1 else float("nan")
            pc = p["close"].iloc[-1] if len(p) >= 1 else float("nan")
            mpm = tot / cfg["window_minutes"]
            score = calc_sentiment_score(b, br, t, tot, max_weight)

            window_data.append({
                "w_start":     ws,
                "w_end":       we,
                "price_open":  po,
                "price_close": pc,
                "total_msgs":  tot,
                "bull":        b,
                "bear":        br,
                "tagged":      t,
                "msg_per_min": mpm,
                "sentiment":   score,
            })

        trades = find_trade_signals(
            ticker,
            window_data,
            cfg["corr_threshold"],
            cfg["msg_threshold"],
            cfg["use_corr"],
            cfg["use_msg"],
        )
        all_trades.extend(trades)
        print(f"  → {len(trades)} trade signal(s) found")
        time.sleep(0.5)

    # ── Step 2: filter and save ──────────────────────────────────────────────
    if not all_trades:
        print("\nNo trades found across all tickers.")
        sys.exit(0)

    df_trades = pd.DataFrame(all_trades)

    # Keep only rows where |pct_change| > 0.3 %
    df_filtered = df_trades[
        df_trades["pct_change"].apply(
            lambda x: abs(x) > 0.3 if x is not None and not math.isnan(x) else False
        )
    ].reset_index(drop=True)

    print(f"\n[Results] {len(df_filtered)} trades with |pct_change| > 0.3%")

    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    out_path  = os.path.join(
        DOWNLOADS_DIR,
        f"sentiment_corr_{cfg['market_cap']}_{cfg['date']}_{timestamp}.csv",
    )
    df_filtered.to_csv(out_path, index=False)
    print(f"\n✓ Saved to: {out_path}")

    # Pretty print summary
    if not df_filtered.empty:
        cols = [
            "ticker", "entry_window", "exit_window",
            "entry_price", "exit_price", "pct_change",
            "entry_corr_price_density", "entry_corr_price_sentiment",
            "exit_corr_price_density",  "exit_corr_price_sentiment",
            "avg_msg_per_min", "trade_sentiment", "exit_reason",
        ]
        print("\n" + df_filtered[cols].to_string(index=False))
    else:
        print("No trades passed the 0.3% filter.")


if __name__ == "__main__":
    main()
