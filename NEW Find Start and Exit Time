# STEP 1 — GET TICKERS FROM FINVIZ
# ════════════════════════════════════════════════════════════
def fetch_tickers(market_cap, auth):
    best_tickers, best_diff = [], float("inf")

    # Progressive relaxation — try strict filters first, loosen if nothing found
    def try_url(filters_str):
        nonlocal best_tickers, best_diff
        encoded = quote(filters_str, safe="")
        url     = f"https://elite.finviz.com/export?v=111&f={encoded}&ft=3&auth={auth}"
        try:
            resp = requests.get(url, headers={"User-Agent": "Mozilla/5.0"}, timeout=15)
            if resp.status_code == 401:
                print("  ❌ Token expired — get a new one from Finviz Elite")
                return False
            if resp.status_code != 200:
                return True
            df = pd.read_csv(io.StringIO(resp.text))
            if "Ticker" not in df.columns: return True
            tickers = df["Ticker"].dropna().astype(str).tolist()
            diff    = abs(len(tickers) - TARGET_TICKERS)
            print(f"  [{filters_str[:40]}...] → {len(tickers)} tickers")
            if diff < best_diff:
                best_diff, best_tickers = diff, tickers
        except Exception as e:
            print(f"  error: {e}")
        return True

    cap  = RAW_CAP_FILTERS[market_cap]
    chg  = CHANGE_FILTERS[market_cap]
    vol1 = "sh_curvol_o100"
    vol2 = "sh_curvol_o50"

    # Level 0: full filters with each relvol
    print("  Trying full filters...")
    for rv in RELVOL_OPTIONS:
        ok = try_url(f"{cap},{vol1},{rv},{chg}")
        if not ok: return []
        time.sleep(0.3)
    if best_tickers: return best_tickers

    # Level 1: no change filter
    print("  Relaxing — removing change filter...")
    for rv in RELVOL_OPTIONS:
        try_url(f"{cap},{vol1},{rv}")
        time.sleep(0.3)
    if best_tickers: return best_tickers

    # Level 2: lower volume threshold
    print("  Relaxing — lowering volume threshold...")
    for rv in RELVOL_OPTIONS:
        try_url(f"{cap},{vol2},{rv}")
        time.sleep(0.3)
    if best_tickers: return best_tickers

    # Level 3: just market cap
    print("  Relaxing — just market cap filter...")
    try_url(cap)
    if best_tickers: return best_tickers

    # Level 4: absolute last resort — all tickers for cap, take first 30
    print("  Last resort — fetching all tickers for this cap...")
    url = f"https://elite.finviz.com/export?v=111&f={cap}&ft=3&auth={auth}"
    try:
        resp = requests.get(url, headers={"User-Agent": "Mozilla/5.0"}, timeout=15)
        if resp.status_code == 200:
            df = pd.read_csv(io.StringIO(resp.text))
            if "Ticker" in df.columns:
                best_tickers = df["Ticker"].dropna().astype(str).tolist()[:TARGET_TICKERS]
                print(f"  Got {len(best_tickers)} tickers")
    except Exception as e:
        print(f"  Last resort error: {e}")

    return best_tickers

