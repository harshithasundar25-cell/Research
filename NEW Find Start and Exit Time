# STEP 2 — HELPERS
# ════════════════════════════════════════════════════════════
def parse_ts(ts_str):
    return datetime.fromisoformat(ts_str.replace("Z", "+00:00"))

def extract_sentiment(msg):
    raw = msg.get("entities", {}).get("sentiment", None)
    return raw.get("basic", "None") if raw else "None"

def smooth(arr, k=5):
    arr = list(arr)
    if len(arr) < k: return arr
    return np.convolve(arr, np.ones(k)/k, mode='same').tolist()

def safe_r(a, b):
    a, b = np.array(a, dtype=float), np.array(b, dtype=float)
    if len(a) < 5 or a.std() == 0 or b.std() == 0: return 0.0
    r, _ = stats.pearsonr(a, b)
    return round(float(r), 4)

# ── Fetch price from Finviz ───────────────────────────────
def fetch_price(ticker):
    url = f"https://elite.finviz.com/quote_export?t={ticker}&p=i1&auth={AUTH_TOKEN}"
    try:
        resp = requests.get(url, headers={"User-Agent": "Mozilla/5.0"}, timeout=15)
        if resp.status_code != 200: return None
        df = pd.read_csv(io.StringIO(resp.text))
        df.columns = [c.strip().lower() for c in df.columns]
        dt_col = next((c for c in df.columns if "date" in c or "time" in c), None)
        if dt_col is None: return None

        # Try 12-hour AM/PM format first, then 24-hour
        df["date"] = pd.to_datetime(
            df[dt_col].astype(str), format="%m/%d/%Y %I:%M %p", errors="coerce"
        )
        if df["date"].isna().all():
            df["date"] = pd.to_datetime(
                df[dt_col].astype(str).str.replace(r"\s+(AM|PM)$", "", regex=True),
                format="%m/%d/%Y %H:%M", errors="coerce"
            )
        df = df.dropna(subset=["date"])
        if len(df) == 0: return None

        # Filter to target date + time range client-side
        start_dt = pd.Timestamp(f"{DATE_STR} {START_TIME}:00")
        end_dt   = pd.Timestamp(f"{DATE_STR} {END_TIME}:00")
        df = df[(df["date"] >= start_dt) & (df["date"] <= end_dt)].copy()
        df = df[["date","close"]].sort_values("date").reset_index(drop=True)
        return df if len(df) >= 5 else None
    except:
        return None

# ── Fetch StockTwits messages ─────────────────────────────
def fetch_messages(ticker):
    api_url = f"https://api.stocktwits.com/api/2/streams/symbol/{ticker}.json"
    headers = {
        "Accept":  "application/json",
        "Referer": f"https://stocktwits.com/symbol/{ticker}",
        "Origin":  "https://stocktwits.com",
    }
    session, collected, max_id, stop, page = cffi_requests.Session(), [], None, False, 0
    while not stop and page < 50:
        page += 1
        try:
            params = {"limit": 30}
            if max_id: params["max"] = max_id
            data     = session.get(api_url, headers=headers, params=params,
                                   timeout=20, impersonate="chrome136").json()
            messages = data.get("messages", [])
            if not messages: break
            last_dt  = parse_ts(messages[-1]["created_at"]).astimezone(EDT)
            if last_dt > WINDOW_END:
                max_id = messages[-1]["id"]; time.sleep(0.3); continue
            for msg in messages:
                msg_edt = parse_ts(msg["created_at"]).astimezone(EDT)
                if msg_edt > WINDOW_END: continue
                if WINDOW_START <= msg_edt <= WINDOW_END:
                    collected.append({
                        "_ts":       msg_edt.replace(tzinfo=None).replace(second=0, microsecond=0),
                        "sentiment": extract_sentiment(msg),
                    })
                elif msg_edt < WINDOW_START:
                    stop = True; break
            max_id = messages[-1]["id"]
            time.sleep(0.8)
        except: break
    return collected

# ── Build rolling windows ─────────────────────────────────
def build_rolling_windows(collected, window_mins):
    mc, mb, mr = defaultdict(int), defaultdict(int), defaultdict(int)
    for m in collected:
        t = m["_ts"]
        mc[t] += 1
        if m["sentiment"] == "Bullish": mb[t] += 1
        if m["sentiment"] == "Bearish": mr[t] += 1

    windows, t = [], WINDOW_START.replace(tzinfo=None)
    t_end = WINDOW_END.replace(tzinfo=None)
    while t + timedelta(minutes=window_mins) <= t_end:
        wend   = t + timedelta(minutes=window_mins)
        keys   = [k for k in mc if t <= k < wend]
        total  = sum(mc[k] for k in keys)
        bull   = sum(mb[k] for k in keys)
        bear   = sum(mr[k] for k in keys)
        tagged = bull + bear
        raw    = (bull - bear) / tagged if tagged > 0 else 0.0
        windows.append({"t": t, "total": total,
                        "weighted": raw * np.log1p(total)})
        t += timedelta(minutes=1)

    if not windows: return None
    max_w = max(abs(w["weighted"]) for w in windows) or 1.0
    for w in windows:
        w["norm_score"] = w["weighted"] / max_w

    return pd.DataFrame({
        "minute":     pd.to_datetime([w["t"]          for w in windows]),
        "density":    [w["total"]      for w in windows],
        "norm_score": [w["norm_score"] for w in windows],
    })

# ── Find entry/exit signals ───────────────────────────────
def find_signals(df, threshold, roll_win):
    if len(df) < roll_win + 2: return []

    df = df.copy().reset_index(drop=True)
    df["price_smooth"]   = smooth(df["close"].values,      k=5)
    df["density_smooth"] = smooth(df["density"].values,    k=5)
    df["score_smooth"]   = smooth(df["norm_score"].values, k=5)

    r_pd_series, r_ps_series = [], []
    for i in range(len(df)):
        if i < roll_win:
            r_pd_series.append(0.0)
            r_ps_series.append(0.0)
        else:
            sl = df.iloc[i-roll_win:i]
            r_pd_series.append(safe_r(sl["density_smooth"], sl["price_smooth"]))
            r_ps_series.append(safe_r(sl["score_smooth"],   sl["price_smooth"]))

    df["r_pd"] = r_pd_series
    df["r_ps"] = r_ps_series
    df["price_rising"] = (
        df["price_smooth"] > df["price_smooth"].shift(5).fillna(df["price_smooth"])
    )

    # Entry: price rising + BOTH correlations >= threshold
    df["entry_signal"] = (
        df["price_rising"] &
        (df["r_pd"] >= threshold) &
        (df["r_ps"] >= threshold)
    )
    # Exit: EITHER correlation drops below threshold
    df["exit_signal"] = (
        (df["r_pd"] < threshold) |
        (df["r_ps"] < threshold)
    )

    signals, in_trade, entry_row = [], False, None

    for i, row in df.iterrows():
        if not in_trade and row["entry_signal"]:
            in_trade, entry_row = True, row
        elif in_trade and row["exit_signal"]:
            pct = round((row["close"] - entry_row["close"]) / entry_row["close"] * 100, 4)
            signals.append({
                "entry_time":     entry_row["date"].strftime("%H:%M"),
                "exit_time":      row["date"].strftime("%H:%M"),
                "entry_price":    round(float(entry_row["close"]), 4),
                "exit_price":     round(float(row["close"]), 4),
                "pct_change":     pct,
                "outcome":        "GAIN" if pct >= 0 else "LOSS",
                "entry_r_pd":     round(float(entry_row["r_pd"]), 4),
                "entry_r_ps":     round(float(entry_row["r_ps"]), 4),
                "exit_r_pd":      round(float(row["r_pd"]), 4),
                "exit_r_ps":      round(float(row["r_ps"]), 4),
                "exit_reason":    (
                    "r_pd below threshold" if row["r_pd"] < threshold and row["r_ps"] >= threshold
                    else "r_ps below threshold" if row["r_ps"] < threshold and row["r_pd"] >= threshold
                    else "both below threshold"
                ),
                "threshold_used": threshold,
                "rolling_window": roll_win,
            })
            in_trade, entry_row = False, None

    # EOD — still in trade
    if in_trade and entry_row is not None:
        last = df.iloc[-1]
        pct  = round((last["close"] - entry_row["close"]) / entry_row["close"] * 100, 4)
        signals.append({
            "entry_time":     entry_row["date"].strftime("%H:%M"),
            "exit_time":      last["date"].strftime("%H:%M") + " (EOD)",
            "entry_price":    round(float(entry_row["close"]), 4),
            "exit_price":     round(float(last["close"]), 4),
            "pct_change":     pct,
            "outcome":        "GAIN (EOD)" if pct >= 0 else "LOSS (EOD)",
            "entry_r_pd":     round(float(entry_row["r_pd"]), 4),
            "entry_r_ps":     round(float(entry_row["r_ps"]), 4),
            "exit_r_pd":      round(float(last["r_pd"]), 4),
            "exit_r_ps":      round(float(last["r_ps"]), 4),
            "exit_reason":    "EOD — no exit signal triggered",
            "threshold_used": threshold,
            "rolling_window": roll_win,
        })

    return signals

# ════════════════════════════════════════════════════════════
# STEP 3 — PROCESS EACH TICKER
# ════════════════════════════════════════════════════════════
all_results = []

for ticker in TICKERS:
    print(f"  {ticker}...", end=" ", flush=True)

    df_price = fetch_price(ticker)
    if df_price is None:
        print("no price data"); continue

    msgs = fetch_messages(ticker)
    if len(msgs) == 0:
        print("no messages"); continue

    win_df = build_rolling_windows(msgs, ROLL_WIN)
    if win_df is None:
        print("no windows"); continue

    df_price["minute"] = df_price["date"].dt.floor("min")
    df = pd.merge(df_price[["date","minute","close"]], win_df, on="minute", how="inner")
    df = df.dropna(subset=["close"]).reset_index(drop=True)

    if len(df) < ROLL_WIN + 2 or df["density"].max() == 0:
        print("insufficient overlap"); continue

    r_pd = safe_r(smooth(df["density"].values,    k=5), smooth(df["close"].values, k=5))
    r_ps = safe_r(smooth(df["norm_score"].values, k=5), smooth(df["close"].values, k=5))
    r_ds = safe_r(smooth(df["density"].values,    k=5), smooth(df["norm_score"].values, k=5))

    signals = find_signals(df, THRESHOLD, ROLL_WIN)
    print(f"{len(msgs)} msgs | r_pd={r_pd:+.3f} r_ps={r_ps:+.3f} | {len(signals)} trade(s)")

    if not signals:
        all_results.append({
            "ticker": ticker, "market_cap": MARKET_CAP, "date": DATE_STR,
            "rolling_window": ROLL_WIN, "threshold_used": THRESHOLD,
            "entry_time": "NO SIGNAL", "exit_time": "NO SIGNAL",
            "entry_price": "", "exit_price": "", "pct_change": "",
            "outcome": "NO SIGNAL", "entry_r_pd": "", "entry_r_ps": "",
            "exit_r_pd": "", "exit_r_ps": "",
            "exit_reason": "Correlations never met threshold",
            "overall_r_pd": r_pd, "overall_r_ps": r_ps, "overall_r_ds": r_ds,
            "total_messages": len(msgs),
        })
    else:
        for sig in signals:
            all_results.append({
                "ticker": ticker, "market_cap": MARKET_CAP, "date": DATE_STR,
                "rolling_window": sig["rolling_window"],
                "threshold_used": sig["threshold_used"],
                "entry_time":     sig["entry_time"],
                "exit_time":      sig["exit_time"],
                "entry_price":    sig["entry_price"],
                "exit_price":     sig["exit_price"],
                "pct_change":     sig["pct_change"],
                "outcome":        sig["outcome"],
                "entry_r_pd":     sig["entry_r_pd"],
                "entry_r_ps":     sig["entry_r_ps"],
                "exit_r_pd":      sig["exit_r_pd"],
                "exit_r_ps":      sig["exit_r_ps"],
                "exit_reason":    sig["exit_reason"],
                "overall_r_pd":   r_pd,
                "overall_r_ps":   r_ps,
                "overall_r_ds":   r_ds,
                "total_messages": len(msgs),
            })

