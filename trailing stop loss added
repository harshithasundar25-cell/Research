        if df_result is not None and not df_result.empty:
            df_result.to_csv(out_path, index=False)
            print(" -> " + str(len(df_result)) + " trades saved: " + filename)
            saved_files.append(out_path)
        else:
            pd.DataFrame(columns=[
                "ticker","entry_window","exit_window","entry_price","exit_price",
                "pct_change","entry_corr_price_density","entry_corr_price_sentiment",
                "exit_corr_price_density","exit_corr_price_sentiment",
                "avg_msg_per_min","trade_sentiment","exit_reason"
            ]).to_csv(out_path, index=False)
            print(" -> 0 trades (empty file saved)")
            saved_files.append(out_path)

    print("\n[Done] " + str(len(saved_files)) + " files saved to " + DOWNLOADS_DIR)


if __name__ == "__main__":
    main()
