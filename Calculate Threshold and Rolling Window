    "mid":   "cap_mid",   "small": "cap_small",
    "micro": "cap_micro", "nano":  "cap_nano",
}
CHANGE_FILTERS = {
    "mega":  "ta_change_u1",  "large": "ta_change_u1",
    "mid":   "ta_change_u5",  "small": "ta_change_u5",
    "micro": "ta_change_u10", "nano":  "ta_change_u10",
}
RELVOL_OPTIONS = [
    "sh_relvol_o0.75","sh_relvol_o1","sh_relvol_o1.5",
    "sh_relvol_o2","sh_relvol_o3","sh_relvol_o5","sh_relvol_o10",
]

MARKET_CAP = input("Market cap (mega/large/mid/small/micro/nano): ").strip().lower()
DATE_STR   = input("Date (YYYY-MM-DD): ").strip()
