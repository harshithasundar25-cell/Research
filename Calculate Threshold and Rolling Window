AUTH_TOKEN     = "9faf63f5-c9b6-4386-b2c0-856d6a96877a"
EDT            = ZoneInfo("America/New_York")
TARGET_TICKERS = 30

WINDOW_RANGE = {
    "nano":  (5,  30),
    "micro": (5,  60),
    "small": (5,  120),
    "mid":   (5,  180),
    "large": (5,  240),
