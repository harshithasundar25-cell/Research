def get_auth_token(email, password):
    LOGIN_URL   = "https://finviz.com/login_submit.ashx"
    ACCOUNT_URL = "https://elite.finviz.com/account.ashx"
    H = {
        "User-Agent":   "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
                        "AppleWebKit/537.36 (KHTML, like Gecko) "
                        "Chrome/124.0.0.0 Safari/537.36",
        "Referer":      "https://finviz.com/login",
        "Origin":       "https://finviz.com",
        "Content-Type": "application/x-www-form-urlencoded",
    }
    s    = requests.Session()
    resp = s.post(LOGIN_URL, data={"email":email,"password":password,"remember":"on"},
                  headers=H, timeout=20, allow_redirects=True)
    if resp.status_code not in (200, 302):
        raise RuntimeError(f"Login HTTP {resp.status_code}")
    if "login" in resp.url.lower() and "account" not in resp.url.lower():
        raise RuntimeError("Wrong email or password.")
    ar = s.get(ACCOUNT_URL, headers={**H,"Referer":"https://finviz.com/"}, timeout=20)
    if ar.status_code != 200:
        raise RuntimeError(f"Account page HTTP {ar.status_code}")
    soup = BeautifulSoup(ar.text, "html.parser")
    for tag in soup.find_all("input"):
        v = tag.get("value","")
        if re.match(r"^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",v,re.I):
            return v
    uuids = re.findall(
        r"[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}",
        ar.text, re.I)
    pl = ar.text.lower()
    for u in uuids:
        ctx = pl[max(0,pl.find(u.lower())-100):pl.find(u.lower())+100]
        if any(k in ctx for k in ("api","auth","token","key","export")):
            return u
    if uuids: return uuids[0]
    raise RuntimeError("Token not found on account page.")

def login_and_get_token():
    print("─"*50)
    print("  Finviz Elite — auto-login")
    print("─"*50)
    email    = input("  Email   : ").strip()
    password = getpass.getpass("  Password: ")
    print("  Logging in...", end=" ", flush=True)
    try:
        tok = get_auth_token(email, password)
        print(f"✅  Token: {tok[:8]}…{tok[-4:]}")
        return tok
    except RuntimeError as e:
        print(f"\n  ❌ {e}\n  Falling back to manual entry.")
        return input("  Paste your auth token: ").strip()

