# STEP 2 — HELPERS
# ════════════════════════════════════════════════════════════
def parse_ts(s):
    return datetime.fromisoformat(s.replace("Z","+00:00"))

def extract_sentiment(msg):
    raw = msg.get("entities",{}).get("sentiment",None)
    return raw.get("basic","None") if raw else "None"

def safe_r(a, b):
    a,b = np.array(a,float), np.array(b,float)
    if len(a)<5 or a.std()==0 or b.std()==0: return 0.0
    r,_ = stats.pearsonr(a,b)
    return round(float(r),4)

def smooth(arr, k=5):
    arr = list(arr)
    if len(arr)<k: return arr
    return np.convolve(arr,np.ones(k)/k,mode="same").tolist()

def fetch_price(ticker):
    url = f"https://elite.finviz.com/quote_export?t={ticker}&p=i1&auth={AUTH_TOKEN}"
    try:
        r = requests.get(url,headers={"User-Agent":"Mozilla/5.0"},timeout=15)
        if r.status_code != 200: return None
        df = pd.read_csv(io.StringIO(r.text))
        df.columns = [c.strip().lower() for c in df.columns]
        dc = next((c for c in df.columns if "date" in c or "time" in c),None)
        if dc is None: return None
        df["date"] = pd.to_datetime(df[dc].astype(str),
                                    format="%m/%d/%Y %I:%M %p",errors="coerce")
        if df["date"].isna().all():
            df["date"] = pd.to_datetime(
                df[dc].astype(str).str.replace(r"\s+(AM|PM)$","",regex=True),
                format="%m/%d/%Y %H:%M",errors="coerce")
        df = df.dropna(subset=["date"])
        if len(df)==0: return None
        s = pd.Timestamp(f"{DATE_STR} {START_TIME}:00")
        e = pd.Timestamp(f"{DATE_STR} {END_TIME}:00")
        df = df[(df["date"]>=s)&(df["date"]<=e)].copy()
        df = df[["date","close"]].sort_values("date").reset_index(drop=True)
        return df if len(df)>=5 else None
    except: return None

def fetch_messages(ticker):
    url  = f"https://api.stocktwits.com/api/2/streams/symbol/{ticker}.json"
    hdrs = {"Accept":"application/json",
            "Referer":f"https://stocktwits.com/symbol/{ticker}",
            "Origin":"https://stocktwits.com"}
    sess,out,max_id,stop,pg = cffi_requests.Session(),[],None,False,0
    while not stop and pg<50:
        pg+=1
        try:
            params={"limit":30}
            if max_id: params["max"]=max_id
            data = sess.get(url,headers=hdrs,params=params,
                            timeout=20,impersonate="chrome136").json()
            msgs = data.get("messages",[])
            if not msgs: break
            last_dt = parse_ts(msgs[-1]["created_at"]).astimezone(EDT)
            if last_dt > WINDOW_END:
                max_id=msgs[-1]["id"]; time.sleep(0.3); continue
            for m in msgs:
                edt = parse_ts(m["created_at"]).astimezone(EDT)
                if edt > WINDOW_END: continue
                if WINDOW_START <= edt <= WINDOW_END:
                    out.append({
                        "_ts": edt.replace(tzinfo=None).replace(second=0,microsecond=0),
                        "sentiment": extract_sentiment(m),
                    })
                elif edt < WINDOW_START: stop=True; break
            max_id=msgs[-1]["id"]
            time.sleep(0.5)
        except: break
    return out

def build_windows(collected, window_mins):
    mc,mb,mr = defaultdict(int),defaultdict(int),defaultdict(int)
    for m in collected:
        t=m["_ts"]; mc[t]+=1
        if m["sentiment"]=="Bullish": mb[t]+=1
        if m["sentiment"]=="Bearish": mr[t]+=1
    rows,t=[],WINDOW_START.replace(tzinfo=None)
    t_end=WINDOW_END.replace(tzinfo=None)
    while t+timedelta(minutes=window_mins)<=t_end:
        wend  = t+timedelta(minutes=window_mins)
        keys  = [k for k in mc if t<=k<wend]
        total = sum(mc[k] for k in keys)
        bull  = sum(mb[k] for k in keys)
        bear  = sum(mr[k] for k in keys)
        tgd   = bull+bear
        raw   = (bull-bear)/tgd if tgd>0 else 0.0
        rows.append({"t":t,"total":total,"weighted":raw*np.log1p(total)})
        t+=timedelta(minutes=1)
    if not rows: return None
    mx=max(abs(w["weighted"]) for w in rows) or 1.0
    for w in rows: w["norm_score"]=w["weighted"]/mx
    return pd.DataFrame({
        "minute":     pd.to_datetime([w["t"] for w in rows]),
        "density":    [w["total"] for w in rows],
        "norm_score": [w["norm_score"] for w in rows],
    })

def merge_df(df_price, win_df):
    dp = df_price.copy()
    dp["minute"] = dp["date"].dt.floor("min")
    df = pd.merge(dp[["date","minute","close"]], win_df, on="minute", how="inner")
    return df.dropna(subset=["close"]).reset_index(drop=True)

def avg_corr_for_window(df_price, collected, window_mins):
    """Returns mean(r_pd, r_ps) for a given window size."""
    win_df = build_windows(collected, window_mins)
    if win_df is None: return 0.0
    df = merge_df(df_price, win_df)
    if len(df)<5 or df["density"].max()==0: return 0.0
    r_pd = safe_r(smooth(df["density"].values,k=5), smooth(df["close"].values,k=5))
    r_ps = safe_r(smooth(df["norm_score"].values,k=5), smooth(df["close"].values,k=5))
    return (r_pd+r_ps)/2

def derive_corr_threshold(df_price, collected, window_mins):
    """
    Derives the correlation threshold at the optimal window by:
      1. Computing rolling r_pd and r_ps at every bar (10-bar lookback)
      2. Measuring how consistently each is positive and how message-dense
         the window is
      3. Returns (thresh_pd, thresh_ps) — take their mean for one number
    """
    win_df = build_windows(collected, window_mins)
    if win_df is None: return 0.3, 0.3
    df = merge_df(df_price, win_df)
    if len(df)<12: return 0.3, 0.3

    df["ps"] = smooth(df["norm_score"].values,k=5)
    df["dn"] = smooth(df["density"].values,   k=5)
    df["pr"] = smooth(df["close"].values,     k=5)

    LB = 10
    rpd_h, rps_h, msg_h = [], [], []
    for i in range(len(df)):
        if i < LB:
            rpd_h.append(0.0); rps_h.append(0.0)
        else:
            sl = df.iloc[i-LB:i]
            rpd_h.append(safe_r(sl["dn"], sl["pr"]))
            rps_h.append(safe_r(sl["ps"], sl["pr"]))
        msg_h.append(df["density"].iloc[i])

    def calc(r_series, msg_counts):
        recent_r    = r_series[-LB:]
        recent_msgs = msg_counts[-LB:]
        consistency = sum(1 for r in recent_r if r>0) / len(recent_r)
        avg_msgs    = np.mean(recent_msgs) if recent_msgs else 0
        vol_bonus   = 0.1 * min(np.log1p(avg_msgs)/np.log1p(50), 1.0)
        return round(0.3 + 0.1*consistency + vol_bonus, 4)

    return calc(rpd_h, msg_h), calc(rps_h, msg_h)

# ════════════════════════════════════════════════════════════
# STEP 3 — PROCESS EACH TICKER
# ════════════════════════════════════════════════════════════
print("="*60)
print("  Fetching data...")
print("="*60)

ticker_rows = []   # one row per ticker: best_window, thresh_pd, thresh_ps, avg_r

for ticker in TICKERS:
    print(f"  {ticker}...", end=" ", flush=True)

    df_price = fetch_price(ticker)
    if df_price is None: print("no price"); continue

    msgs = fetch_messages(ticker)
    if not msgs: print("no messages"); continue

    # ── Search every window size, find the one with max avg correlation ──
    best_w, best_r = WIN_MIN, -999.0
    window_scores  = {}

    for w in range(WIN_MIN, WIN_MAX+1, WIN_STEP):
        r = avg_corr_for_window(df_price.copy(), msgs, w)
        window_scores[w] = r
        if r > best_r:
            best_r, best_w = r, w

    # ── Derive correlation threshold at the optimal window ──
    t_pd, t_ps = derive_corr_threshold(df_price.copy(), msgs, best_w)

    print(f"best_window={best_w}m  avg_r={best_r:+.4f}  "
          f"thresh_pd={t_pd:.4f}  thresh_ps={t_ps:.4f}")

    ticker_rows.append({
        "ticker":       ticker,
        "best_window":  best_w,
        "best_avg_r":   round(best_r, 4),
        "thresh_pd":    t_pd,
        "thresh_ps":    t_ps,
        "avg_thresh":   round((t_pd+t_ps)/2, 4),
        "n_messages":   len(msgs),
    })

# ════════════════════════════════════════════════════════════
# STEP 4 — AGGREGATE & OUTPUT
# ════════════════════════════════════════════════════════════
if not ticker_rows:
    day_name = datetime(*date_parts).strftime("%A")
    print(f"\n⚠️  No usable data returned.")
    print(f"   {DATE_STR} is a {day_name} — confirm it is a trading day.")
    print(f"   Also check that the token is valid and tickers have StockTwits activity.")
else:
    df_r = pd.DataFrame(ticker_rows)

    # ── Optimal window: weighted mean by avg_r so high-correlation
    #    tickers have more influence; then round to nearest WIN_STEP ──
    weights    = np.clip(df_r["best_avg_r"].values, 0, None)
    w_sum      = weights.sum()
    if w_sum > 0:
        weighted_win = float(np.average(df_r["best_window"].values, weights=weights))
    else:
        weighted_win = float(df_r["best_window"].mean())

    OPT_WINDOW = int(round(weighted_win / WIN_STEP) * WIN_STEP)
    OPT_WINDOW = max(WIN_MIN, min(WIN_MAX, OPT_WINDOW))   # clamp to valid range

    # ── Optimal threshold: median of per-ticker avg_thresh values ──
    # Median is more robust than mean — one outlier ticker won't skew it
    OPT_THRESH = round(float(df_r["avg_thresh"].median()), 4)

    # ── Per-ticker breakdown table ────────────────────────────
    print(f"\n{'═'*65}")
    print(f"  {MARKET_CAP.upper()} | {DATE_STR} | {START_TIME}–{END_TIME}")
    print(f"{'═'*65}")
    print(f"\n  Per-ticker breakdown ({len(df_r)} tickers):\n")
    pd.set_option("display.float_format", lambda x: f"{x:.4f}")
    print(df_r[["ticker","best_window","best_avg_r",
                "thresh_pd","thresh_ps","avg_thresh","n_messages"]
              ].to_string(index=False))

    # ── Distribution summary ──────────────────────────────────
    print(f"\n  Window distribution:")
    print(f"    min={df_r['best_window'].min()}  "
          f"median={df_r['best_window'].median():.0f}  "
          f"mean={df_r['best_window'].mean():.1f}  "
          f"max={df_r['best_window'].max()}")
    print(f"  Threshold distribution:")
    print(f"    min={df_r['avg_thresh'].min():.4f}  "
          f"median={df_r['avg_thresh'].median():.4f}  "
          f"mean={df_r['avg_thresh'].mean():.4f}  "
          f"max={df_r['avg_thresh'].max():.4f}")

    # ── THE ANSWER ────────────────────────────────────────────
    print(f"\n{'═'*65}")
    print(f"  ✅  OPTIMAL ROLLING WINDOW   :  {OPT_WINDOW} minutes")
    print(f"  ✅  OPTIMAL CORR THRESHOLD   :  {OPT_THRESH}")
    print(f"{'═'*65}\n")

    # ── Save CSV ──────────────────────────────────────────────
    out = f"{MARKET_CAP}_{DATE_STR}_{START_TIME.replace(':','')}_{END_TIME.replace(':','')}_window_thresh.csv"
    df_r.to_csv(out, index=False)
    files.download(out)
    print(f"  CSV → {out}")
