def fetch_tickers(market_cap):
    best, best_diff = [], float("inf")
    def try_url(f_str):
        nonlocal best, best_diff
        url = (f"https://elite.finviz.com/export?v=111"
               f"&f={quote(f_str, safe='')}&ft=3&auth={AUTH_TOKEN}")
        try:
            r = requests.get(url, headers={"User-Agent":"Mozilla/5.0"}, timeout=15)
            if r.status_code == 401: print("  ❌ Token expired"); return False
            if r.status_code != 200: return True
            df = pd.read_csv(io.StringIO(r.text))
            if "Ticker" not in df.columns: return True
            t  = df["Ticker"].dropna().astype(str).tolist()
            d  = abs(len(t) - TARGET_TICKERS)
            print(f"  [{f_str[:55]}] → {len(t)}")
            if d < best_diff: best_diff, best = d, t
        except Exception as e: print(f"  err: {e}")
        return True

    cap, chg = RAW_CAP_FILTERS[market_cap], CHANGE_FILTERS[market_cap]
    for rv in RELVOL_OPTIONS:
        if not try_url(f"{cap},sh_curvol_o100,{rv},{chg}"): return []
        time.sleep(0.3)
    if best: return best
    for rv in RELVOL_OPTIONS:
        try_url(f"{cap},sh_curvol_o100,{rv}"); time.sleep(0.3)
    if best: return best
    for rv in RELVOL_OPTIONS:
        try_url(f"{cap},sh_curvol_o50,{rv}"); time.sleep(0.3)
    if best: return best
    try_url(cap)
    if best: return best
    try:
        r  = requests.get(
            f"https://elite.finviz.com/export?v=111&f={cap}&ft=3&auth={AUTH_TOKEN}",
            headers={"User-Agent":"Mozilla/5.0"}, timeout=15)
        df = pd.read_csv(io.StringIO(r.text))
        if "Ticker" in df.columns:
            best = df["Ticker"].dropna().astype(str).tolist()[:TARGET_TICKERS]
    except: pass
    return best

print("Scanning Finviz...")
TICKERS = fetch_tickers(MARKET_CAP)
