PCT_CHANGE_THRESHOLDS = {
    "nano":  10.0,
    "micro": 10.0,
    "small":  5.0,
    "mid":    5.0,
    "large":  0.5,
    "mega":   0.5,
}

FIXED_THRESHOLD  = 0.3
FIXED_WINDOW_MIN = 360
FIXED_STOP_PCT   = 30.0

THRESHOLD_VALUES = [round(x * 0.1, 1) for x in range(1, 11)]
WINDOW_VALUES    = list(range(10, 970, 10))
STOP_VALUES      = [5, 10, 15, 20, 25, 30]

