def curl_get(url, params=None, timeout=30):
    return curl_requests.get(
        url,
        params=params,
        timeout=timeout,
        impersonate="chrome110",
        headers={"User-Agent": "Mozilla/5.0"},
        allow_redirects=True,
    )

# ---------------------------------------------------------------------------
# PRICE DATA  (unchanged from original)
# ---------------------------------------------------------------------------

def get_price_data(ticker, date):
    url = (
        "https://elite.finviz.com/quote_export?"
        "t=" + ticker +
        "&p=i1&s=" + date +
        "&e=" + date +
        "&auth=" + AUTH_TOKEN
    )
    try:
        resp = curl_get(url, timeout=30)
        if resp.status_code != 200:
            return pd.DataFrame()
        df = pd.read_csv(StringIO(resp.text))
        df.columns = [c.strip().lower() for c in df.columns]
        dt_col = next((c for c in df.columns if "date" in c or "time" in c), None)
        if dt_col is None:
            return pd.DataFrame()
        df[dt_col] = df[dt_col].astype(str).str.replace(r"\s+(AM|PM)$", "", regex=True)
        df[dt_col] = pd.to_datetime(df[dt_col], format="%m/%d/%Y %H:%M", errors="coerce")
        df = df.dropna(subset=[dt_col])
        df = df.rename(columns={dt_col: "datetime"})
        if df["datetime"].dt.tz is None:
            df["datetime"] = df["datetime"].dt.tz_localize(EST)
        return df[["datetime", "close"]].sort_values("datetime").reset_index(drop=True)
    except Exception as e:
        print("    Price fetch error for " + ticker + ": " + str(e))
        return pd.DataFrame()

# ---------------------------------------------------------------------------
# STOCKTWITS SENTIMENT  (unchanged from original)
# ---------------------------------------------------------------------------

def fetch_stocktwits_messages(ticker, date):
    base = "https://api.stocktwits.com/api/2/streams/symbol/" + ticker + ".json"
    date_dt   = datetime.strptime(date, "%Y-%m-%d")
    day_start = EST.localize(date_dt.replace(hour=0,  minute=0,  second=0))
    day_end   = EST.localize(date_dt.replace(hour=23, minute=59, second=59))

    rows   = []
    max_id = None
    stop   = False
    page   = 0

    while not stop and page < 40:
        params = {"limit": 30}
        if max_id:
            params["max"] = max_id
        try:
            resp = curl_get(base, params=params, timeout=20)
            if resp.status_code != 200:
                break
            data = resp.json()
        except Exception:
            break

        messages = data.get("messages", [])
        if not messages:
            break

        for msg in messages:
            raw_ts = msg.get("created_at", "")
            try:
                ts_utc = datetime.strptime(raw_ts, "%Y-%m-%dT%H:%M:%SZ")
                ts_utc = pytz.utc.localize(ts_utc)
                ts_est = ts_utc.astimezone(EST)
            except Exception:
                continue
            if ts_est < day_start:
                stop = True
                break
            if ts_est > day_end:
                continue
            sentiment = (msg.get("entities") or {}).get("sentiment") or {}
            label  = (sentiment.get("basic") or "").lower()
            bull   = 1 if label == "bullish" else 0
            bear   = 1 if label == "bearish" else 0
            tagged = 1 if label in ("bullish", "bearish") else 0
            rows.append({
                "datetime": ts_est,
                "bull":     bull,
                "bear":     bear,
                "tagged":   tagged,
                "total":    1,
            })

        max_id = messages[-1].get("id")
        page  += 1
        time.sleep(0.3)

    if not rows:
        return pd.DataFrame(columns=["datetime", "bull", "bear", "tagged", "total"])
    return pd.DataFrame(rows).sort_values("datetime").reset_index(drop=True)

# ---------------------------------------------------------------------------
# ROLLING WINDOW HELPERS  (unchanged from original)
# ---------------------------------------------------------------------------

def hhmm_to_minutes(hhmm):
    h, m = map(int, hhmm.split(":"))
    return h * 60 + m


def calc_sentiment_score(bull, bear, tagged, total, max_weight=1.0):
    if tagged == 0 or max_weight == 0:
        return float("nan")
    return ((bull - bear) / tagged * math.log(1 + total)) / max_weight


def build_rolling_windows(start_hhmm, end_hhmm, window_minutes, date):
    base      = datetime.strptime(date, "%Y-%m-%d")
    start_min = hhmm_to_minutes(start_hhmm)
    end_min   = hhmm_to_minutes(end_hhmm)
    windows   = []
    cur       = start_min
    while cur + window_minutes <= end_min + 1:
        ws = EST.localize(base.replace(hour=cur // 60, minute=cur % 60, second=0))
        we = EST.localize(base.replace(
            hour=(cur + window_minutes) // 60,
            minute=(cur + window_minutes) % 60,
            second=0,
        ))
        windows.append((ws, we))
        cur += 1   # <-- original: overlapping, slide 1 minute at a time
    return windows


def safe_corr(x, y):
    pairs = [(a, b) for a, b in zip(x, y) if not math.isnan(a) and not math.isnan(b)]
    if len(pairs) < 3:
        return float("nan")
    xs, ys = zip(*pairs)
    try:
        r, _ = pearsonr(xs, ys)
        return r
    except Exception:
        return float("nan")

# ---------------------------------------------------------------------------
# TRADE SIGNAL LOGIC  (copied verbatim from original find_trade_signals)
# ---------------------------------------------------------------------------

def find_trade_signals(ticker, all_windows, entry_corr_threshold, trailing_stop_pct, use_corr):
    trades       = []
    in_trade     = False
    entry_idx    = None
    peak_corr_pd = None
    peak_corr_ps = None

    prices     = [w["price_close"] for w in all_windows]
    densities  = [w["msg_per_min"] for w in all_windows]
    sentiments = [w["sentiment"]   for w in all_windows]

    corr_pd = []
    corr_ps = []
    for i in range(len(all_windows)):
        lo = max(0, i - 9)
        corr_pd.append(safe_corr(prices[lo:i+1], densities[lo:i+1]))
        corr_ps.append(safe_corr(prices[lo:i+1], sentiments[lo:i+1]))

    for i, w in enumerate(all_windows):
        price_rising = (
            not math.isnan(w["price_open"])
            and not math.isnan(w["price_close"])
            and w["price_close"] > w["price_open"]
        )

        r_pd = corr_pd[i]
        r_ps = corr_ps[i]

        entry_corr_ok     = True
        trailing_stop_hit = False

        if use_corr:
            entry_corr_ok = (
                not math.isnan(r_pd) and not math.isnan(r_ps)
                and r_pd >= entry_corr_threshold and r_ps >= entry_corr_threshold
            )
            if in_trade and trailing_stop_pct is not None:
                if not math.isnan(r_pd) and peak_corr_pd is not None:
                    peak_corr_pd = max(peak_corr_pd, r_pd)
                if not math.isnan(r_ps) and peak_corr_ps is not None:
                    peak_corr_ps = max(peak_corr_ps, r_ps)
                stop_fraction = trailing_stop_pct / 100.0
                pd_stopped = (
                    peak_corr_pd is not None
                    and not math.isnan(r_pd)
                    and r_pd < peak_corr_pd * (1 - stop_fraction)
                )
                ps_stopped = (
                    peak_corr_ps is not None
                    and not math.isnan(r_ps)
                    and r_ps < peak_corr_ps * (1 - stop_fraction)
                )
                trailing_stop_hit = pd_stopped or ps_stopped

        if not in_trade:
            if price_rising and entry_corr_ok:
                in_trade     = True
                entry_idx    = i
                peak_corr_pd = r_pd if not math.isnan(r_pd) else None
                peak_corr_ps = r_ps if not math.isnan(r_ps) else None
        else:
            exit_reason = None
            if not price_rising:
                exit_reason = "price_decreasing"
            elif use_corr and trailing_stop_hit:
                exit_reason = "corr_trailing_stop_" + str(trailing_stop_pct) + "pct"

            if exit_reason or i == len(all_windows) - 1:
                if exit_reason is None:
                    exit_reason = "end_of_window"
                if i == entry_idx:
                    in_trade     = False
                    entry_idx    = None
                    peak_corr_pd = None
                    peak_corr_ps = None
                    continue

                entry_w     = all_windows[entry_idx]
                exit_w      = all_windows[i]
                entry_price = entry_w["price_open"]
                exit_price  = exit_w["price_close"]
                pct_change  = (
                    (exit_price - entry_price) / entry_price * 100
                    if entry_price and entry_price != 0 else float("nan")
                )

                trade_windows   = all_windows[entry_idx:i+1]
                total_m  = sum(tw["total_msgs"]  for tw in trade_windows)
                total_b  = sum(tw["bull"]        for tw in trade_windows)
                total_br = sum(tw["bear"]        for tw in trade_windows)
                total_t  = sum(tw["tagged"]      for tw in trade_windows)
                avg_mpm  = sum(tw["msg_per_min"] for tw in trade_windows) / len(trade_windows)

                max_weight = max(
                    (abs((tw["bull"] - tw["bear"]) / tw["tagged"] * math.log(1 + tw["total_msgs"]))
                     for tw in trade_windows if tw["tagged"] > 0),
                    default=1.0,
                )
                trade_sentiment = calc_sentiment_score(total_b, total_br, total_t, total_m, max_weight)

                valid_peaks    = [v for v in [peak_corr_pd, peak_corr_ps] if v is not None]
                max_corr_value = round(sum(valid_peaks) / len(valid_peaks), 4) if valid_peaks else None

                trades.append({
                    "ticker":                       ticker,
                    "entry_window":                 entry_w["w_start"].strftime("%H:%M"),
                    "exit_window":                  exit_w["w_end"].strftime("%H:%M"),
                    "entry_price":                  round(entry_price, 4) if not math.isnan(entry_price) else None,
                    "exit_price":                   round(exit_price,  4) if not math.isnan(exit_price)  else None,
                    "pct_change":                   round(pct_change,  4) if not math.isnan(pct_change)  else None,
                    "entry_corr_price_density":     round(corr_pd[entry_idx], 4) if not math.isnan(corr_pd[entry_idx]) else None,
                    "entry_corr_price_sentiment":   round(corr_ps[entry_idx], 4) if not math.isnan(corr_ps[entry_idx]) else None,
                    "exit_corr_price_density":      round(corr_pd[i], 4)         if not math.isnan(corr_pd[i])         else None,
                    "exit_corr_price_sentiment":    round(corr_ps[i], 4)         if not math.isnan(corr_ps[i])         else None,
                    "max_corr":                     max_corr_value,
                    "avg_msg_per_min":              round(avg_mpm,        4) if not math.isnan(avg_mpm)          else None,
                    "trade_sentiment":              round(trade_sentiment, 4) if not math.isnan(trade_sentiment)  else None,
                    "exit_reason":                  exit_reason,
                })

                in_trade     = False
                entry_idx    = None
                peak_corr_pd = None
                peak_corr_ps = None

    return trades

# ---------------------------------------------------------------------------
# RUN ONE WINDOW SIZE  (copied verbatim from original run_for_window)
# ---------------------------------------------------------------------------

def run_for_window(tickers, price_cache, msg_cache, date,
                   window_minutes, entry_corr_threshold, trailing_stop_pct,
                   pct_change_threshold, use_corr):

    windows_meta = build_rolling_windows("04:00", "20:00", window_minutes, date)
    all_trades   = []

    for ticker in tickers:
        price_df = price_cache.get(ticker, pd.DataFrame())
        msg_df   = msg_cache.get(ticker, pd.DataFrame())

        if price_df.empty:
            continue

        total_msgs_for_ticker = int(msg_df["total"].sum()) if not msg_df.empty else 0
        if total_msgs_for_ticker == 0 and use_corr:
            continue

        all_msg_windows = []
        for ws, we in windows_meta:
            m   = msg_df[(msg_df["datetime"] >= ws) & (msg_df["datetime"] < we)] if not msg_df.empty else pd.DataFrame()
            b   = int(m["bull"].sum())   if not m.empty else 0
            br  = int(m["bear"].sum())   if not m.empty else 0
            t   = int(m["tagged"].sum()) if not m.empty else 0
            tot = int(m["total"].sum())  if not m.empty else 0
            all_msg_windows.append((b, br, t, tot))

        max_weight = max(
            (abs((b - br) / t * math.log(1 + tot))
             for b, br, t, tot in all_msg_windows if t > 0),
            default=1.0,
        )

        window_data = []
        for (ws, we), (b, br, t, tot) in zip(windows_meta, all_msg_windows):
            p  = price_df[(price_df["datetime"] >= ws) & (price_df["datetime"] < we)]
            po = p["close"].iloc[0]  if len(p) >= 1 else float("nan")
            pc = p["close"].iloc[-1] if len(p) >= 1 else float("nan")
            mpm   = tot / window_minutes
            score = calc_sentiment_score(b, br, t, tot, max_weight)
            window_data.append({
                "w_start":     ws,
                "w_end":       we,
                "price_open":  po,
                "price_close": pc,
                "total_msgs":  tot,
                "bull":        b,
                "bear":        br,
                "tagged":      t,
                "msg_per_min": mpm,
                "sentiment":   score,
            })

        trades = find_trade_signals(
            ticker, window_data,
            entry_corr_threshold, trailing_stop_pct,
            use_corr,
        )
        all_trades.extend(trades)

    if not all_trades:
        return pd.DataFrame()

    df = pd.DataFrame(all_trades)
    df = df[
        df["pct_change"].apply(
            lambda x: x > pct_change_threshold if x is not None and not math.isnan(x) else False
        )
    ].reset_index(drop=True)
    return df

# ---------------------------------------------------------------------------
# MAIN
# ---------------------------------------------------------------------------

def main():
    print("\n" + "=" * 60)
    print("  Parameter Sweep Optimizer")
    print("=" * 60)

    # What to optimize
    opt_mode = ""
    while opt_mode not in ("threshold", "window", "stop loss"):
        opt_mode = input(
            "\nWhat are you optimizing? (threshold / window / stop loss): "
        ).strip().lower()

    # Date
    date = input("Date (YYYY-MM-DD): ").strip()

    # Market cap
    valid_caps = ["nano", "micro", "small", "mid", "large", "mega"]
    market_cap = ""
    while market_cap not in valid_caps:
        market_cap = input("Market cap (nano/micro/small/mid/large/mega): ").strip().lower()

    pct_threshold = PCT_CHANGE_THRESHOLDS[market_cap]

    # Ticker CSV
    csv_path = input("Path to ticker CSV file: ").strip().strip("'\"")
    if not os.path.exists(csv_path):
        print("File not found: " + csv_path)
        sys.exit(1)
    df_src  = pd.read_csv(csv_path)
    col_map = {c.strip().lower(): c for c in df_src.columns}
    if "ticker" not in col_map:
        print("No Ticker column found. Columns: " + str(df_src.columns.tolist()))
        sys.exit(1)
    tickers = df_src[col_map["ticker"]].dropna().astype(str).str.strip().tolist()
    print("Loaded " + str(len(tickers)) + " tickers: " + str(tickers))

    # Fetch price + sentiment once
    print("\nFetching price & sentiment data...")
    price_cache = {}
    msg_cache   = {}
    for ticker in tickers:
        print("  [" + ticker + "] fetching...")
        price_cache[ticker] = get_price_data(ticker, date)
        msg_cache[ticker]   = fetch_stocktwits_messages(ticker, date)
        msgs = int(msg_cache[ticker]["total"].sum()) if not msg_cache[ticker].empty else 0
        print("    price_rows=" + str(len(price_cache[ticker])) + "  messages=" + str(msgs))
        time.sleep(0.4)

    # Build sweep values and fixed params
    if opt_mode == "threshold":
        sweep_values     = THRESHOLD_VALUES
        use_corr         = True
        trailing_stop    = FIXED_STOP_PCT
        window_minutes   = FIXED_WINDOW_MIN
        print("\nSweeping threshold: " + str(sweep_values))
        print("Fixed: window=" + str(window_minutes) + "min  stop=" + str(trailing_stop) + "%")

    elif opt_mode == "window":
        sweep_values     = WINDOW_VALUES
        use_corr         = True
        trailing_stop    = FIXED_STOP_PCT
        entry_corr       = FIXED_THRESHOLD
        print("\nSweeping window: 10 → 960 min (" + str(len(sweep_values)) + " values)")
        print("Fixed: threshold=" + str(entry_corr) + "  stop=" + str(trailing_stop) + "%")

    else:  # stop loss
        sweep_values     = STOP_VALUES
        use_corr         = True
        entry_corr       = FIXED_THRESHOLD
        window_minutes   = FIXED_WINDOW_MIN
        print("\nSweeping stop loss: " + str(sweep_values))
        print("Fixed: threshold=" + str(entry_corr) + "  window=" + str(window_minutes) + "min")

    # Run sweep
    print("\nRunning sweep...")
    for val in sweep_values:
        if opt_mode == "threshold":
            entry_corr     = val
            wm             = window_minutes
            stop           = trailing_stop
            label          = "threshold" + str(val)
        elif opt_mode == "window":
            wm             = val
            stop           = trailing_stop
            label          = "window" + str(val) + "min"
        else:
            stop           = val
            wm             = window_minutes
            label          = "stop" + str(val) + "pct"
            entry_corr     = FIXED_THRESHOLD

        df_result = run_for_window(
            tickers, price_cache, msg_cache, date,
            wm, entry_corr, stop, pct_threshold, use_corr,
        )

        out_filename = (
            date + "-" + label
            + "-" + market_cap + ".csv"
        )
        out_path = os.path.join(DOWNLOADS_DIR, out_filename)

        if df_result is not None and not df_result.empty:
            df_result.to_csv(out_path, index=False)
            print("  " + label + " -> " + str(len(df_result)) + " trades  [" + out_filename + "]")
        else:
            pd.DataFrame(columns=[
                "ticker", "entry_window", "exit_window", "entry_price", "exit_price",
                "pct_change", "entry_corr_price_density", "entry_corr_price_sentiment",
                "exit_corr_price_density", "exit_corr_price_sentiment",
                "max_corr", "avg_msg_per_min", "trade_sentiment", "exit_reason",
            ]).to_csv(out_path, index=False)
            print("  " + label + " -> 0 trades  [" + out_filename + "]")

    print("\n[Done] All files saved to: " + DOWNLOADS_DIR)


if __name__ == "__main__":
    main()
