WINDOW_VALUES    = list(range(10, 970, 10))
STOP_VALUES      = [5, 10, 15, 20, 25, 30]

# ---------------------------------------------------------------------------
# HTTP
# ---------------------------------------------------------------------------

def curl_get(url, params=None, timeout=30):
    return curl_requests.get(
        url,
        params=params,
        timeout=timeout,
        impersonate="chrome110",
        headers={"User-Agent": "Mozilla/5.0"},
        allow_redirects=True,
    )

# ---------------------------------------------------------------------------
# PRICE DATA
# ---------------------------------------------------------------------------

def get_price_data(ticker, date):
    url = (
        "https://elite.finviz.com/quote_export?"
        "t=" + ticker +
        "&p=i1&s=" + date +
        "&e=" + date +
        "&auth=" + AUTH_TOKEN
    )
    try:
        resp = curl_get(url, timeout=30)
        if resp.status_code != 200:
            return pd.DataFrame()
        df = pd.read_csv(StringIO(resp.text))
        df.columns = [c.strip().lower() for c in df.columns]
        dt_col = next((c for c in df.columns if "date" in c or "time" in c), None)
        if dt_col is None:
            return pd.DataFrame()
        df[dt_col] = df[dt_col].astype(str).str.replace(r"\s+(AM|PM)$", "", regex=True)
        df[dt_col] = pd.to_datetime(df[dt_col], format="%m/%d/%Y %H:%M", errors="coerce")
        df = df.dropna(subset=[dt_col])
        df = df.rename(columns={dt_col: "datetime"})
        if df["datetime"].dt.tz is None:
            df["datetime"] = df["datetime"].dt.tz_localize(EST)
        return df[["datetime", "close"]].sort_values("datetime").reset_index(drop=True)
    except Exception as e:
        print("    Price fetch error for " + ticker + ": " + str(e))
        return pd.DataFrame()

# ---------------------------------------------------------------------------
# STOCKTWITS MESSAGES
# ---------------------------------------------------------------------------

def fetch_stocktwits_messages(ticker, date):
    base      = "https://api.stocktwits.com/api/2/streams/symbol/" + ticker + ".json"
    date_dt   = datetime.strptime(date, "%Y-%m-%d")
    day_start = EST.localize(date_dt.replace(hour=0,  minute=0,  second=0))
    day_end   = EST.localize(date_dt.replace(hour=23, minute=59, second=59))

    rows   = []
    max_id = None
    stop   = False
    page   = 0

    while not stop and page < 40:
        params = {"limit": 30}
        if max_id:
            params["max"] = max_id
        try:
            resp = curl_get(base, params=params, timeout=20)
            if resp.status_code != 200:
                break
            data = resp.json()
        except Exception:
            break

        messages = data.get("messages", [])
        if not messages:
            break

        for msg in messages:
            raw_ts = msg.get("created_at", "")
            try:
                ts_utc = datetime.strptime(raw_ts, "%Y-%m-%dT%H:%M:%SZ")
                ts_utc = pytz.utc.localize(ts_utc)
                ts_est = ts_utc.astimezone(EST)
            except Exception:
                continue
            if ts_est < day_start:
                stop = True
                break
            if ts_est > day_end:
                continue
            rows.append({"datetime": ts_est, "total": 1})

        max_id = messages[-1].get("id")
        page  += 1
        time.sleep(0.3)

    if not rows:
        return pd.DataFrame(columns=["datetime", "total"])
    return pd.DataFrame(rows).sort_values("datetime").reset_index(drop=True)

# ---------------------------------------------------------------------------
# HELPERS
# ---------------------------------------------------------------------------

def hhmm_to_minutes(hhmm):
    h, m = map(int, hhmm.split(":"))
    return h * 60 + m


def build_rolling_windows(start_hhmm, end_hhmm, window_minutes, date):
    base      = datetime.strptime(date, "%Y-%m-%d")
    start_min = hhmm_to_minutes(start_hhmm)
    end_min   = hhmm_to_minutes(end_hhmm)
    windows   = []
    cur       = start_min
    while cur + window_minutes <= end_min + 1:
        ws = EST.localize(base.replace(hour=cur // 60, minute=cur % 60, second=0))
        we = EST.localize(base.replace(
            hour=(cur + window_minutes) // 60,
            minute=(cur + window_minutes) % 60,
            second=0,
        ))
        windows.append((ws, we))
        cur += 1  # overlapping: slide 1 minute at a time
    return windows


def safe_corr(x, y):
    pairs = [(a, b) for a, b in zip(x, y)
             if not math.isnan(a) and not math.isnan(b)]
    if len(pairs) < 3:
        return float("nan")
    xs, ys = zip(*pairs)
    try:
        r, _ = pearsonr(xs, ys)
        return r
    except Exception:
        return float("nan")

# ---------------------------------------------------------------------------
# TRADE SIGNAL LOGIC
#
# KEY FIX — one trade per price move:
#   The overlapping windows mean the same price move could open a new
#   position every minute. We prevent this by jumping `i` forward to
#   the exit window index after each trade closes, so no windows that
#   overlap with an already-counted move can trigger a new entry.
#
# NO PCT_CHANGE FILTER:
#   All trades are recorded regardless of move size so win rate and
#   profitability reflect what a real account would see.
# ---------------------------------------------------------------------------

def find_trade_signals(ticker, all_windows, entry_corr_threshold, trailing_stop_pct):
    trades       = []
    peak_corr_pd = None

    prices    = [w["price_close"] for w in all_windows]
    densities = [w["msg_per_min"] for w in all_windows]

    # Pre-compute rolling correlation across ALL windows (lookback 10)
    corr_pd = []
    for i in range(len(all_windows)):
        lo = max(0, i - 9)
        corr_pd.append(safe_corr(prices[lo:i+1], densities[lo:i+1]))

    i = 0
    while i < len(all_windows):
        w    = all_windows[i]
        r_pd = corr_pd[i]

        price_rising = (
            not math.isnan(w["price_open"])
            and not math.isnan(w["price_close"])
            and w["price_close"] > w["price_open"]
        )
        entry_corr_ok = (
            not math.isnan(r_pd)
            and r_pd >= entry_corr_threshold
        )

        if not (price_rising and entry_corr_ok):
            i += 1
            continue

        # ----- ENTERED a trade -----
        entry_idx    = i
        peak_corr_pd = r_pd if not math.isnan(r_pd) else None
        exit_idx     = None
        exit_reason  = None

        j = i + 1
        while j < len(all_windows):
            wj    = all_windows[j]
            r_pdj = corr_pd[j]

            price_rising_j = (
                not math.isnan(wj["price_open"])
                and not math.isnan(wj["price_close"])
                and wj["price_close"] > wj["price_open"]
            )

            # Update peak correlation while in trade
            if not math.isnan(r_pdj) and peak_corr_pd is not None:
                peak_corr_pd = max(peak_corr_pd, r_pdj)

            # Check trailing stop
            trailing_stop_hit = False
            if trailing_stop_pct is not None:
                stop_fraction = trailing_stop_pct / 100.0
                trailing_stop_hit = (
                    peak_corr_pd is not None
                    and not math.isnan(r_pdj)
                    and r_pdj < peak_corr_pd * (1 - stop_fraction)
                )

            if not price_rising_j:
                exit_idx    = j
                exit_reason = "price_decreasing"
                break
            elif trailing_stop_hit:
                exit_idx    = j
                exit_reason = "corr_trailing_stop_" + str(trailing_stop_pct) + "pct"
                break

            j += 1

        # If we never hit an exit condition, close at last window
        if exit_idx is None:
            exit_idx    = len(all_windows) - 1
            exit_reason = "end_of_session"

        # Skip same-window flicker
        if exit_idx == entry_idx:
            i += 1
            continue

        entry_w     = all_windows[entry_idx]
        exit_w      = all_windows[exit_idx]
        entry_price = entry_w["price_open"]
        exit_price  = exit_w["price_close"]

        if entry_price and entry_price != 0 and not math.isnan(entry_price) and not math.isnan(exit_price):
            pct_change = (exit_price - entry_price) / entry_price * 100

            trade_windows = all_windows[entry_idx:exit_idx + 1]
            total_m = sum(tw["total_msgs"] for tw in trade_windows)
            avg_mpm = sum(tw["msg_per_min"] for tw in trade_windows) / len(trade_windows)

            trades.append({
                "ticker":                   ticker,
                "entry_window":             entry_w["w_start"].strftime("%H:%M"),
                "exit_window":              exit_w["w_end"].strftime("%H:%M"),
                "entry_price":              round(entry_price, 4),
                "exit_price":               round(exit_price,  4),
                "pct_change":               round(pct_change,  4),
                "entry_corr_price_density": round(corr_pd[entry_idx], 4) if not math.isnan(corr_pd[entry_idx]) else None,
                "exit_corr_price_density":  round(corr_pd[exit_idx],  4) if not math.isnan(corr_pd[exit_idx])  else None,
                "peak_corr_price_density":  round(peak_corr_pd, 4) if peak_corr_pd is not None else None,
                "avg_msg_per_min":          round(avg_mpm, 4),
                "total_msgs_in_trade":      total_m,
                "exit_reason":              exit_reason,
            })

        # Resume from the window after exit — can re-enter on a new move
        # but cannot overlap with the trade that just closed
        i = exit_idx + 1

    return trades

# ---------------------------------------------------------------------------
# RUN ONE PARAMETER SET
# ---------------------------------------------------------------------------

def run_for_window(tickers, price_cache, msg_cache, date,
                   window_minutes, entry_corr_threshold, trailing_stop_pct):

    windows_meta = build_rolling_windows("04:00", "20:00", window_minutes, date)
    all_trades   = []

    for ticker in tickers:
        price_df = price_cache.get(ticker, pd.DataFrame())
        msg_df   = msg_cache.get(ticker, pd.DataFrame())

        if price_df.empty:
            continue

        total_msgs_for_ticker = int(msg_df["total"].sum()) if not msg_df.empty else 0
        if total_msgs_for_ticker == 0:
            continue

        # Aggregate message counts per window
        all_msg_windows = []
        for ws, we in windows_meta:
            m   = msg_df[(msg_df["datetime"] >= ws) & (msg_df["datetime"] < we)] if not msg_df.empty else pd.DataFrame()
            tot = int(m["total"].sum()) if not m.empty else 0
            all_msg_windows.append(tot)

        # Build per-window data
        window_data = []
        for (ws, we), tot in zip(windows_meta, all_msg_windows):
            p   = price_df[(price_df["datetime"] >= ws) & (price_df["datetime"] < we)]
            po  = p["close"].iloc[0]  if len(p) >= 1 else float("nan")
            pc  = p["close"].iloc[-1] if len(p) >= 1 else float("nan")
            mpm = tot / window_minutes
            window_data.append({
                "w_start":     ws,
                "w_end":       we,
                "price_open":  po,
                "price_close": pc,
                "total_msgs":  tot,
                "msg_per_min": mpm,
            })

        trades = find_trade_signals(
            ticker, window_data,
            entry_corr_threshold, trailing_stop_pct,
        )
        all_trades.extend(trades)

    if not all_trades:
        return pd.DataFrame()

    # NO pct_change filter — return all trades as-is
    return pd.DataFrame(all_trades).reset_index(drop=True)

