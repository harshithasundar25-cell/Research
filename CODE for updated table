            "total_messages":   len(msgs),
        })
    else:
        for sig in signals:
            all_results.append({
                "ticker":           ticker,
                "market_cap":       MARKET_CAP,
                "date":             DATE_STR,
                "rolling_window":   sig["rolling_window"],
                "r_lookback":       sig["r_lookback"],
                "threshold_used":   sig["threshold_used"],
                "sent_threshold":   sig["sent_threshold"],
                "msg_threshold":    sig["msg_threshold"],
                "avg_sentiment":    avg_sentiment,
                "avg_msgs_per_min": avg_density,
                "entry_time":       sig["entry_time"],
                "exit_time":        sig["exit_time"],
                "entry_price":      sig["entry_price"],
                "exit_price":       sig["exit_price"],
                "pct_change":       sig["pct_change"],
                "outcome":          sig["outcome"],
                "entry_r_pd":       sig["entry_r_pd"],
                "entry_r_ps":       sig["entry_r_ps"],
                "entry_sentiment":  sig["entry_sentiment"],
                "entry_msgs_min":   sig["entry_msgs_min"],
                "exit_r_pd":        sig["exit_r_pd"],
                "exit_r_ps":        sig["exit_r_ps"],
                "exit_reason":      sig["exit_reason"],
                "overall_r_pd":     r_pd,
                "overall_r_ps":     r_ps,
                "overall_r_ds":     r_ds,
                "total_messages":   len(msgs),
            })

# ════════════════════════════════════════════════════════════
# STEP 4 — SAVE CSV
# ════════════════════════════════════════════════════════════
if not all_results:
    print("\n⚠️  No data — check date is a trading day and token is valid.")
else:
    results_df = pd.DataFrame(all_results)

    has_signal = results_df["outcome"] != "NO SIGNAL"
    df_trades  = results_df[has_signal].copy()
    df_nosig   = results_df[~has_signal].copy()

    df_trades["pct_change"] = pd.to_numeric(df_trades["pct_change"], errors="coerce")
    df_trades  = df_trades.sort_values("pct_change", ascending=False)
    results_df = pd.concat([df_trades, df_nosig]).reset_index(drop=True)

    trades = df_trades.copy()
    n_gain = trades["outcome"].str.contains("GAIN").sum()
    n_loss = trades["outcome"].str.contains("LOSS").sum()

    print(f"\n{'='*65}")
    print(f"  {MARKET_CAP.upper()} | {DATE_STR} | window={ROLL_WIN}min | r_lookback={R_LOOKBACK}min")
    print(f"  corr_thresh={THRESHOLD} | sent_thresh={SENT_THRESHOLD} | msg_thresh={MSG_THRESHOLD}")
    print(f"  Total tickers processed : {results_df['ticker'].nunique()}")
    print(f"  Tickers with signals    : {trades['ticker'].nunique()}")
    print(f"  Total trades            : {len(trades)}")
    print(f"  Gains                   : {n_gain}")
    print(f"  Losses                  : {n_loss}")
    if len(trades) > 0 and trades["pct_change"].notna().any():
        print(f"  Avg pct change          : {trades['pct_change'].mean():+.2f}%")
    print(f"{'='*65}")

    if len(trades) > 0:
        print(f"\nAll trades:")
        print(trades[["ticker","entry_time","exit_time","entry_price","exit_price",
                       "pct_change","outcome","entry_r_pd","entry_r_ps",
                       "entry_sentiment","entry_msgs_min","exit_reason"]].to_string(index=False))

    out = (f"{MARKET_CAP}_{DATE_STR}_"
           f"w{ROLL_WIN}_t{str(THRESHOLD).replace('.','p')}_signals.csv")
    results_df.to_csv(out, index=False)
    print(f"\n✅ Saved → {out}")
