def get_token_via_browser():
    """Open Finviz Elite API page, grab the token automatically."""
    print("Opening Finviz Elite to fetch API token...")
    chrome_options = Options()
    # Remove headless so user can log in if needed
    driver = webdriver.Chrome(options=chrome_options)
    driver.get("https://elite.finviz.com/api_explanation")

    # Wait for user to log in if redirected
    print("If a login page appeared, please log in. Waiting up to 60 seconds...")
    try:
        # Wait until the API explanation page loads (looks for token on page)
        WebDriverWait(driver, 60).until(
            lambda d: "api_explanation" in d.current_url or "elite.finviz.com" in d.current_url
        )
        time.sleep(3)  # let page fully render

        # Try to extract token from page source
        page_source = driver.page_source
        # Token pattern: 8-4-4-4-12 UUID format
        token_match = re.search(
            r'auth=([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})',
            page_source
        )
        if not token_match:
            # Also try looking for it in links on the page
            links = driver.find_elements(By.TAG_NAME, "a")
            for link in links:
                href = link.get_attribute("href") or ""
                m = re.search(
                    r'auth=([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})',
                    href
                )
                if m:
                    token_match = m
                    break

        driver.quit()

        if token_match:
            token = token_match.group(1)
            print(f"✅ Token found: {token}")
            # Cache it
            with open(TOKEN_FILE, "w") as f:
                json.dump({"token": token, "fetched_at": datetime.now().isoformat()}, f)
            return token
        else:
            print("⚠️  Could not find token automatically.")
            print("    Please paste your token from https://elite.finviz.com/api_explanation")
            return input("Token: ").strip()

    except Exception as e:
        driver.quit()
        print(f"Browser error: {e}")
        return input("Paste token manually: ").strip()

def get_auth_token():
    """Return cached token or fetch a new one if expired/missing."""
    # Check cached token
    if os.path.exists(TOKEN_FILE):
        with open(TOKEN_FILE) as f:
            data = json.load(f)
        token    = data.get("token","")
        fetched  = datetime.fromisoformat(data.get("fetched_at", "2000-01-01"))
        age_hrs  = (datetime.now() - fetched).total_seconds() / 3600

        if age_hrs < 23:  # tokens typically last 24h
            # Quick validity check
            test_url = f"https://elite.finviz.com/export?v=111&f=cap_nano&ft=3&auth={token}"
            try:
                r = requests.get(test_url, headers={"User-Agent": "Mozilla/5.0"}, timeout=10)
                if r.status_code == 200:
                    print(f"✅ Using cached token (age: {age_hrs:.1f}h)")
                    return token
                else:
                    print(f"  Cached token invalid (status {r.status_code}), fetching new one...")
            except:
                pass

    return get_token_via_browser()

