            "entry_time":       "NO SIGNAL",
            "exit_time":        "NO SIGNAL",
            "entry_price":      "",
            "exit_price":       "",
            "pct_change":       "",
            "outcome":          "NO SIGNAL",
            "entry_r_pd":       "",
            "entry_r_ps":       "",
            "entry_sentiment":  "",
            "entry_msgs_min":   "",
            "exit_r_pd":        "",
