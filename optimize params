FIXED_WINDOW_MIN  = 360
FIXED_STOP_PCT    = 30.0

# Sweep ranges
THRESHOLD_VALUES  = [round(x * 0.1, 1) for x in range(1, 11)]   # 0.1 .. 1.0
WINDOW_VALUES     = list(range(10, 970, 10))                       # 10 .. 960
